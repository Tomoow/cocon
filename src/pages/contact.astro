---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ContactForm from '../components/ContactForm.astro';
import sendMessageLottie from '../assets/images/send-message.lottie?url';
import mailSentLottie from '../assets/images/mail-sent.json?url';
---

<BaseLayout title="Contact" description="Contacteer Cocon Kinesitherapie in Kapelle-op-den-Bos. Stuur ons een bericht via het contactformulier of bel 0456 86 46 65.">
  <div class="page-header container-content">
    <SectionHeading
      title="Contactformulier"
      subtitle="Heb je een vraag die je liever via mail stelt? Laat ze hieronder achter en we antwoorden zo snel mogelijk."
      align="center"
    />
  </div>

  <section class="contact-section container-content fade-in" aria-labelledby="contact-heading">
    <h2 id="contact-heading" class="sr-only">Contactformulier</h2>
    <div class="contact-section__illustration" aria-hidden="true">
      <dotlottie-wc
        id="contact-lottie"
        src={sendMessageLottie}
        class="contact-section__lottie"
        data-default-src={sendMessageLottie}
        data-success-src={mailSentLottie}
      ></dotlottie-wc>
    </div>
    <div class="contact-section__form">
      <ContactForm />
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding-top: 8.5rem;
    padding-bottom: 2.5rem;
  }

  @media (min-width: 768px) {
    .page-header {
      padding-top: 10.5rem;
    }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .contact-section {
    display: flex;
    /* Mobile/tablet: form on top, lottie illustration below.
       Switches to a regular row at >=1024px (see media query). */
    flex-direction: column-reverse;
    align-items: center;
    gap: 1.5rem;
    padding-bottom: 5rem;
  }

  .contact-section__illustration {
    width: 100%;
    max-width: 420px;
    display: flex;
    justify-content: center;
  }

  .contact-section__illustration :global(.contact-section__lottie) {
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    display: block;
  }

  .contact-section__form {
    width: 100%;
    max-width: 36rem;
  }

  @media (min-width: 1024px) {
    .contact-section {
      flex-direction: row;
      align-items: center;
      gap: 0;
      padding-bottom: 8rem;
    }

    .contact-section__illustration {
      flex-shrink: 0;
      max-width: 480px;
    }

    .contact-section__form {
      flex: 1;
      max-width: none;
    }
  }
</style>

<script>
  // Register the <dotlottie-wc> custom element. Side-effect import.
  import '@lottiefiles/dotlottie-wc';

  /**
   * Submission animation flow:
   *
   *   idle ── submit ──▶ sending  ─ "send-message" lottie plays ─▶ sent
   *                       (btn disabled, label "Versturen ...")
   *
   *                            ─ "mail-sent" lottie plays ─▶ idle
   *                              (label "Verstuurd")            (label reset, form cleared)
   *
   * The lottie WC initialises async, so every play call goes through
   * `withInstance` which waits for `.dotLottie` to exist on the element.
   */

  // We treat the WC as untyped — the upstream `@lottiefiles/dotlottie-web`
  // types aren't exported from `@lottiefiles/dotlottie-wc`, and using `any`
  // here keeps the script readable. The runtime contract is just:
  //   instance.play(), instance.stop(),
  //   instance.addEventListener('load' | 'complete', handler)
  //
  // Note: the inner DotLottie instance has NO `setSrc()` method — to load
  // a different file you must change the WC element's `src` attribute,
  // which triggers the WC's attributeChangedCallback → calls
  // `dotLottie.load({src: newSrc, ...})` internally. The instance itself
  // persists across attribute changes, so event listeners on it survive.
  type AnyInstance = {
    play(): void;
    stop(): void;
    addEventListener(type: string, handler: () => void): void;
    removeEventListener(type: string, handler: () => void): void;
  };

  type LottieElement = HTMLElement & {
    dotLottie?: AnyInstance | null;
    renderConfig?: { devicePixelRatio?: number };
  };

  const lottie = document.getElementById('contact-lottie') as LottieElement | null;
  const form = document.querySelector<HTMLFormElement>('form.contact-form');
  const submitBtn = form?.querySelector<HTMLButtonElement>('.contact-form__submit');
  const submitLabel = form?.querySelector<HTMLElement>('.contact-form__submit-label');
  const errorBanner = form?.querySelector<HTMLElement>('[data-contact-error]');

  /**
   * POST the form data to /api/contact. The endpoint sends a MIME email
   * via the worker's `CONTACT_EMAIL` send_email binding (see
   * src/pages/api/contact.ts and the binding in wrangler.jsonc).
   *
   * In `astro dev` the binding isn't available and the endpoint returns
   * 503; we treat that as a soft-success so the animation flow can be
   * previewed locally without deploying. In production this branch is
   * never taken — the binding is wired by Cloudflare.
   */
  async function sendContactForm(formEl: HTMLFormElement): Promise<{ ok: boolean; error?: string }> {
    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        body: new FormData(formEl),
      });
      const body = (await res.json().catch(() => ({}))) as { ok?: boolean; error?: string };
      if (res.ok && body.ok) return { ok: true };
      if (res.status === 503 && import.meta.env.DEV) {
        // Local dev — binding isn't wired. Pretend success so we can
        // exercise the visual flow.
        return { ok: true };
      }
      return {
        ok: false,
        error:
          body.error ??
          `Verzenden mislukt (HTTP ${res.status}). Probeer het later opnieuw of mail rechtstreeks naar info@kine-cocon.be.`,
      };
    } catch {
      return {
        ok: false,
        error: 'Netwerkfout. Controleer je verbinding of mail rechtstreeks naar info@kine-cocon.be.',
      };
    }
  }

  function showError(message: string) {
    if (!errorBanner) return;
    errorBanner.textContent = message;
    errorBanner.removeAttribute('hidden');
  }

  function hideError() {
    if (!errorBanner) return;
    errorBanner.setAttribute('hidden', '');
    errorBanner.textContent = '';
  }

  if (lottie && form && submitBtn && submitLabel) {
    const defaultLabel = submitLabel.dataset.defaultLabel ?? 'Bericht versturen';
    const sendingLabel = submitLabel.dataset.sendingLabel ?? 'Versturen ...';
    const sentLabel = submitLabel.dataset.sentLabel ?? 'Verstuurd';
    const defaultSrc = lottie.dataset.defaultSrc ?? lottie.getAttribute('src') ?? '';
    const successSrc = lottie.dataset.successSrc ?? '';

    // Crisp rendering on retina screens
    lottie.renderConfig = { devicePixelRatio: window.devicePixelRatio || 2 };

    let state: 'idle' | 'sending' | 'sent' = 'idle';

    /** Run `callback` once the WC has finished initialising its inner instance. */
    function withInstance(callback: (instance: AnyInstance) => void): void {
      let attempts = 0;
      const check = () => {
        const inst = lottie!.dotLottie;
        if (inst) {
          callback(inst);
          return;
        }
        // Bail after ~5s (300 frames at 60fps) so we never busy-loop forever
        if (attempts++ < 300) requestAnimationFrame(check);
      };
      check();
    }

    /**
     * Load `src` fresh and play it once. Resolves when the 'complete' event
     * fires (with a minimum dwell time so the state is readable, and a max
     * timeout so the flow can never hang).
     *
     * Implementation: we drive the WC by changing its `src` *attribute*
     * (not `instance.setSrc` — that method does not exist). The WC's
     * attributeChangedCallback calls `dotLottie.load({src: newSrc, ...})`
     * internally, which fires the inner instance's 'load' event when ready.
     *
     * The cache-bust query (`?_=<timestamp>`) ensures the new attribute
     * value is always different from the previous one — otherwise the WC's
     * `attributeChangedCallback` skips the change (old === new check) and
     * the animation never reloads/replays.
     */
    function playOnce(src: string, minMs = 1200, maxMs = 6000): Promise<void> {
      return new Promise((resolve) => {
        withInstance((instance) => {
          const startedAt = performance.now();
          let resolved = false;
          let dwellTimer: number | null = null;

          const tryFinish = () => {
            if (resolved) return;
            const elapsed = performance.now() - startedAt;
            if (elapsed < minMs) {
              // Wait out the remainder of the min-dwell so the user actually
              // sees the label/animation pair before we transition
              if (dwellTimer == null) {
                dwellTimer = window.setTimeout(tryFinish, minMs - elapsed);
              }
              return;
            }
            resolved = true;
            instance.removeEventListener('complete', tryFinish);
            if (dwellTimer != null) window.clearTimeout(dwellTimer);
            window.clearTimeout(maxTimer);
            resolve();
          };

          const maxTimer = window.setTimeout(tryFinish, maxMs);

          const onLoad = () => {
            instance.removeEventListener('load', onLoad);
            instance.addEventListener('complete', tryFinish);
            try { instance.play(); } catch { /* will be caught by maxTimer */ }
          };

          instance.addEventListener('load', onLoad);

          // Mutate the WC's src attribute. Different value every call (cache
          // bust) so attributeChangedCallback fires and the inner instance
          // re-runs `dotLottie.load(...)`.
          const bust = src.includes('?') ? '&' : '?';
          lottie!.setAttribute('src', `${src}${bust}_=${Date.now()}`);
        });
      });
    }

    /** Swap the lottie back to the resting send-message illustration. */
    function restoreDefaultLottie() {
      const bust = defaultSrc.includes('?') ? '&' : '?';
      lottie!.setAttribute('src', `${defaultSrc}${bust}_=${Date.now()}`);
    }

    form.addEventListener('submit', async (e) => {
      // Let the browser surface its native validation for missing fields
      if (!form.checkValidity()) return;
      e.preventDefault();
      if (state !== 'idle') return;

      hideError();

      // Stage 1 — sending: disable, "Versturen ...", play send-message lottie.
      // We fire the fetch in parallel with the animation so the user perceives
      // a single smooth flow rather than fetch-then-animation latency.
      state = 'sending';
      submitBtn.disabled = true;
      submitBtn.setAttribute('aria-busy', 'true');
      submitLabel.textContent = sendingLabel;

      const fetchPromise = sendContactForm(form);
      await Promise.all([playOnce(defaultSrc), fetchPromise.then(() => {}, () => {})]);
      const result = await fetchPromise;

      // Failure: roll back to idle, show the error inline, leave the form
      // contents intact so the user doesn't have to retype.
      if (!result.ok) {
        state = 'idle';
        submitBtn.disabled = false;
        submitBtn.removeAttribute('aria-busy');
        submitLabel.textContent = defaultLabel;
        showError(result.error ?? 'Er ging iets mis. Probeer het later opnieuw.');
        restoreDefaultLottie();
        return;
      }

      // Track the successful submission in Umami. We only fire on success
      // (not on validation failure or network error) so the metric reflects
      // actual delivered messages. The optional chaining guards against
      // ad-blockers that block umami's script. See docs/TRACKING.md.
      (window as unknown as { umami?: { track: (name: string) => void } }).umami?.track?.('form-contact-submit');

      // Success: continue into the "Verstuurd" stage, play the mail-sent
      // lottie, then reset everything to idle and clear the form.
      state = 'sent';
      submitLabel.textContent = sentLabel;
      await playOnce(successSrc);

      state = 'idle';
      submitBtn.disabled = false;
      submitBtn.removeAttribute('aria-busy');
      submitLabel.textContent = defaultLabel;
      form.reset();
      restoreDefaultLottie();
    });
  }
</script>
