---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ContactForm from '../components/ContactForm.astro';
import sendMessageLottie from '../assets/images/send-message.lottie?url';
import mailSentLottie from '../assets/images/mail-sent.json?url';
---

<BaseLayout title="Contact" description="Contacteer Cocon. Heb je een vraag? Laat een bericht achter en we antwoorden zo snel mogelijk.">
  <div class="page-header container-content">
    <SectionHeading
      title="Contactformulier"
      subtitle="Heb je een vraag die je liever via mail stelt? Laat ze hieronder achter en we antwoorden zo snel mogelijk."
      align="center"
    />
  </div>

  <section class="contact-section container-content fade-in" aria-labelledby="contact-heading">
    <h2 id="contact-heading" class="sr-only">Contactformulier</h2>
    <div class="contact-section__illustration" aria-hidden="true">
      <dotlottie-wc
        id="contact-lottie"
        src={sendMessageLottie}
        class="contact-section__lottie"
        data-default-src={sendMessageLottie}
        data-success-src={mailSentLottie}
      ></dotlottie-wc>
    </div>
    <div class="contact-section__form">
      <ContactForm />
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding-top: 8.5rem;
    padding-bottom: 2.5rem;
  }

  @media (min-width: 768px) {
    .page-header {
      padding-top: 10.5rem;
    }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .contact-section {
    display: flex;
    /* Mobile/tablet: form on top, lottie illustration below.
       Switches to a regular row at >=1024px (see media query). */
    flex-direction: column-reverse;
    align-items: center;
    gap: 1.5rem;
    padding-bottom: 5rem;
  }

  .contact-section__illustration {
    width: 100%;
    max-width: 420px;
    display: flex;
    justify-content: center;
  }

  .contact-section__illustration :global(.contact-section__lottie) {
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    display: block;
  }

  .contact-section__form {
    width: 100%;
    max-width: 36rem;
  }

  @media (min-width: 1024px) {
    .contact-section {
      flex-direction: row;
      align-items: center;
      gap: 0;
      padding-bottom: 8rem;
    }

    .contact-section__illustration {
      flex-shrink: 0;
      max-width: 480px;
    }

    .contact-section__form {
      flex: 1;
      max-width: none;
    }
  }
</style>

<script>
  // Register the dotlottie web component (defines <dotlottie-wc>)
  import '@lottiefiles/dotlottie-wc';

  type LottieElement = HTMLElement & {
    dotLottie?: { play(): void; setSrc?(src: string): void } | null;
    renderConfig?: { devicePixelRatio?: number };
  };

  const lottie = document.getElementById('contact-lottie') as LottieElement | null;
  const form = document.querySelector<HTMLFormElement>('form.contact-form');
  const submitBtn = form?.querySelector<HTMLButtonElement>('.contact-form__submit');
  const submitLabel = form?.querySelector<HTMLElement>('.contact-form__submit-label');

  if (lottie && form && submitBtn && submitLabel) {
    // After-submit reset delay (give the user time to see "Verstuurd" + the success lottie)
    const RESET_DELAY_MS = 3500;

    const defaultLabel = submitLabel.dataset.defaultLabel ?? submitLabel.textContent ?? 'Bericht versturen';
    const sentLabel = submitLabel.dataset.sentLabel ?? 'Verstuurd';
    const defaultSrc = lottie.dataset.defaultSrc ?? lottie.getAttribute('src') ?? '';
    const successSrc = lottie.dataset.successSrc ?? '';

    let isSubmitting = false;

    // Render at the device pixel ratio so the canvas isn't pixelated on retina screens
    lottie.renderConfig = {
      devicePixelRatio: window.devicePixelRatio || 2,
    };

    function setLottieSrc(src: string) {
      if (!src) return;
      // Some versions of dotlottie-wc expose setSrc on the instance; otherwise reset the attribute.
      if (lottie!.dotLottie?.setSrc) {
        lottie!.dotLottie.setSrc(src);
      } else {
        lottie!.setAttribute('src', src);
      }
    }

    function resetToDefault() {
      isSubmitting = false;
      submitLabel!.textContent = defaultLabel;
      submitBtn!.disabled = false;
      submitBtn!.removeAttribute('aria-busy');
      setLottieSrc(defaultSrc);
      form!.reset();
    }

    form.addEventListener('submit', (e) => {
      // Native validation handles missing fields
      if (!form.checkValidity()) return;
      // Always intercept — we don't actually post anywhere (email setup pending)
      e.preventDefault();
      if (isSubmitting) return;
      isSubmitting = true;

      // Swap to success state: success lottie + "Verstuurd" label, disable button
      setLottieSrc(successSrc);
      submitLabel!.textContent = sentLabel;
      submitBtn!.disabled = true;
      submitBtn!.setAttribute('aria-busy', 'true');

      // Give the success lottie a moment to play, then reset everything to default
      window.setTimeout(resetToDefault, RESET_DELAY_MS);
    });
  }
</script>
