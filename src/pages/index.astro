---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ExpertisesCarousel from '../components/ExpertisesCarousel.astro';
import AfspraakCta from '../components/AfspraakCta.astro';
import ReviewSection from '../components/ReviewSection.astro';
import PraktijkSection from '../components/PraktijkSection.astro';
import settings from '../../content/settings.json';
import imgBekkenbodem from '../assets/images/expertises/bekkenbodem.webp';
import imgZwangerschap from '../assets/images/expertises/zwangerschap.webp';
import imgOrtopedisch from '../assets/images/expertises/ortopedisch.webp';
import imgAlgemeneKine from '../assets/images/expertises/algemene-kine.webp';

// 4 expertises in a 2×2 grid (Figma 0:648 desktop, 0:1913 mobile).
// `description` and `backParagraphs` may contain inline HTML — they're
// rendered with `set:html` in InfoCard. Keep the markup limited to
// <strong> for keyword scanning; if you need richer formatting,
// also extend InfoCard's strong-styling CSS.
const expertisesCards = [
  {
    imageSrc: imgBekkenbodem,
    imageAlt: '', // Decorative; card title provides the same info (avoids redundant alt)
    number: '01',
    title: 'Bekkenbodemtherapie',
    description:
      'Heb je last van <strong>urineverlies</strong>, <strong>obstipatie</strong>, een <strong>zwaar gevoel</strong> of andere klachten in de bekkenbodem? Bekkenbodemtherapie kan helpen. Bij zowel <strong>vrouwen als mannen</strong>.',
    backParagraphs: [
      'De bekkenbodem speelt een belangrijke rol bij <strong>plassen, stoelgang en seksualiteit</strong>. Je kan terecht bij klachten zoals <strong>urineverlies, aandrang, constipatie, bekkenpijn, vaginale klachten</strong> of ander ongemak in de bekkenregio. Deze klachten kunnen een grote impact hebben op het dagelijks leven.',
      'Met een persoonlijke aanpak gaan we samen op zoek naar de oorzaak en werken we gericht aan <strong>herstel</strong>. Tijdens de behandeling besteden we onder andere aandacht aan <strong>toilethouding</strong>, het leren ontspannen en aanspannen van de <strong>bekkenbodemspieren</strong> en, indien nodig, het gebruik van <strong>biofeedback</strong> om de spieren beter te leren aanvoelen en trainen.',
    ],
  },
  {
    imageSrc: imgZwangerschap,
    imageAlt: '',
    number: '02',
    title: 'Zwangerschap & postnataal herstel',
    description:
      'Tijdens en na een <strong>zwangerschap</strong> verandert er veel in je lichaam. Met gerichte kinesitherapie helpen we je om <strong>klachten te voorkomen</strong>, te <strong>herstellen</strong> en je lichaam opnieuw te vertrouwen.',
    backParagraphs: [
      'Tijdens de zwangerschap verandert er veel in je lichaam. <strong>Vanaf 12 weken zwangerschap</strong> kan je terecht voor begeleiding om klachten te voorkomen of vroegtijdig aan te pakken. We werken aan <strong>bewustwording en controle van de bekkenbodemspieren</strong> en bereiden je voor op de <strong>bevalling</strong>, met uitleg over arbeid, weeën en hoe je je lichaam hierbij kan ondersteunen. Dit kan <strong>individueel of samen met je partner</strong>.',
      'Na de <strong>bevalling</strong> begeleiden we je herstel op jouw tempo. Samen werken we aan een veilige opbouw, afgestemd op jouw lichaam en doelen, van comfortabel bewegen in het dagelijks leven tot een <strong>terugkeer naar sport</strong>.',
    ],
  },
  {
    imageSrc: imgOrtopedisch,
    imageAlt: '',
    number: '03',
    title: 'Orthopedische revalidatie',
    description:
      'Na een <strong>operatie</strong>, <strong>blessure</strong> of lange periode van klachten begeleiden we je stap voor stap naar <strong>herstel</strong>, aangepast aan jouw lichaam en tempo.',
    backParagraphs: [
      'Orthopedische revalidatie ondersteunt je herstel na een <strong>operatie, blessure of ongeval</strong>. We begeleiden je stap voor stap in het terug opbouwen van <strong>mobiliteit, kracht en vertrouwen</strong> in bewegen. Alles gebeurt op jouw tempo en wordt afgestemd op jouw mogelijkheden en persoonlijke doelen.',
      'In de eerste weken na een ingreep, of wanneer verplaatsen nog moeilijk is, zijn <strong>huisbezoeken</strong> mogelijk zodat de revalidatie vlot en comfortabel kan starten in je eigen omgeving.',
      'Voorbeelden van klachten of ingrepen: <strong>meniscusoperatie</strong>, <strong>kruisbandreconstructie</strong>, <strong>heup-, schouder- of knieprothese</strong>, <strong>enkelverstuiking of -breuk</strong>, <strong>schouderproblemen</strong> (zoals rotator cuff letsel) of herstel na <strong>fracturen en sportblessures</strong>.',
    ],
  },
  {
    imageSrc: imgAlgemeneKine,
    imageAlt: '',
    number: '04',
    title: 'Algemene kinesitherapie',
    description:
      'Algemene kinesitherapie voor <strong>spier- en gewrichtsklachten</strong>, met <strong>oefentherapie</strong>, <strong>manuele therapie</strong> en <strong>dry needling</strong>.',
    backParagraphs: [
      'Algemene kinesitherapie helpt bij <strong>spier- en gewrichtsklachten</strong> zoals <strong>pijn, stijfheid of overbelasting</strong>, na een blessure, operatie of bij langdurige klachten.',
      'De behandeling wordt afgestemd op jouw noden en bestaat vaak uit <strong>oefentherapie</strong> om kracht, controle en beweeglijkheid stap voor stap op te bouwen. Indien nodig kunnen ook <strong>manuele therapie</strong> en <strong>dry needling</strong> worden ingezet.',
      'Het doel is om je opnieuw vlot en zo comfortabel mogelijk te laten bewegen in het <strong>dagelijks leven, werk of sport</strong>, met aandacht voor herstel en het <strong>voorkomen van terugkerende klachten</strong>.',
    ],
  },
];

const reviewData = [
  {
    quote: 'De zorg die ik van Lynn ontving was ongekend. Ze nam de tijd om mijn behoeften echt te begrijpen en stelde een behandelplan op dat werkte voor mijn lichaam en mijn leven.',
    authorName: 'Sophie M.',
    authorRole: 'Patiënt',
  },
  {
    quote: 'Professionele begeleiding en een warme aanpak. Ik voelde me van begin tot eind in goede handen.',
    authorName: 'Marc D.',
    authorRole: 'Patiënt',
  },
  {
    quote: 'Na mijn zwangerschap heeft de perinatale kinesitherapie me enorm geholpen. Een echte aanrader.',
    authorName: 'Emma V.',
    authorRole: 'Patiënt',
  },
];
---

<BaseLayout
  title="Home"
  description="Cocon is een kinesitherapiepraktijk in Kapelle-op-den-Bos, gespecialiseerd in bekkenbodemtherapie, zwangerschapsbegeleiding, revalidatie en algemene klachten."
  isHome
>
  <Hero
    announcementEnabled={settings.heroAnnouncementEnabled}
    announcementText={settings.heroAnnouncementText}
  />
  <!-- <div>, not <main>: BaseLayout already renders the single <main>
       landmark; a nested main is invalid HTML. The id stays — it's the
       hero scroll-button anchor. -->
  <div id="content-after-hero" class="main-with-ellipses">
    <div class="expertise-ellipses" aria-hidden="true">
      <img class="expertise-ellipses__left" src="/images/ellipse-left.svg" alt="" width="752" height="1025" loading="lazy" />
      <img class="expertise-ellipses__right" src="/images/ellipse-right.svg" alt="" width="850" height="1159" loading="lazy" />
    </div>
    <div class="container-content pt-[6.25rem] pb-24 md:pb-32 expertise-content-on-top">
      <ExpertisesCarousel cards={expertisesCards} class="fade-in" />
    </div>
  </div>
  <AfspraakCta class="fade-in" />
  <PraktijkSection class="fade-in" />
  <div class="container-content pt-16 pb-24 md:pt-20 md:pb-32 fade-in">
    <ReviewSection reviews={reviewData} ctaHref="https://g.page/r/CXVzgVIW61pxEAE/review" />
  </div>
</BaseLayout>
