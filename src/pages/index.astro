---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ExpertisesCarousel from '../components/ExpertisesCarousel.astro';
import AfspraakCta from '../components/AfspraakCta.astro';
import ReviewSection from '../components/ReviewSection.astro';
import PraktijkSection from '../components/PraktijkSection.astro';
import settings from '../../content/settings.json';
import expertise1 from '../assets/images/expertises/expertise-1.png';
import expertise2 from '../assets/images/expertises/expertise-2.png';
import expertise3 from '../assets/images/expertises/expertise-3.png';
import expertise5 from '../assets/images/expertises/expertise-5.png';

// 4 expertises in a 2×2 grid (Figma 0:648 desktop, 0:1913 mobile).
const expertisesCards = [
  {
    imageSrc: expertise1,
    imageAlt: '', // Decorative; card title provides the same info (avoids redundant alt)
    number: '01',
    title: 'Bekkenbodemtherapie',
    description:
      'Heb je last van urineverlies, obstipatie, een zwaar gevoel of andere klachten in de bekkenbodem? Bekkenbodemtherapie kan helpen. Bij zowel vrouwen en mannen.',
    backParagraphs: [
      'De bekkenbodem speelt een belangrijke rol bij plassen, stoelgang en seksualiteit. Je kan terecht bij klachten zoals urineverlies, aandrang, constipatie, bekkenpijn, vaginale klachten of ander ongemak in de bekkenregio. Deze klachten kunnen een grote impact hebben op het dagelijks leven.',
      'Met een persoonlijke aanpak gaan we samen op zoek naar de oorzaak en werken we gericht aan herstel. Tijdens de behandeling besteden we onder andere aandacht aan toilethouding, het leren ontspannen en aanspannen van de bekkenbodemspieren en, indien nodig, het gebruik van biofeedback om de spieren beter te leren aanvoelen en trainen.',
    ],
  },
  {
    imageSrc: expertise2,
    imageAlt: '',
    number: '02',
    title: 'Zwangerschap & postnatale',
    description:
      'Tijdens en na een zwangerschap verandert er veel in je lichaam. Met gerichte kinesitherapie helpen we je om klachten te voorkomen, te herstellen en je lichaam opnieuw te vertrouwen.',
    backParagraphs: [
      'Tijdens de zwangerschap verandert er veel in je lichaam. Vanaf 12 weken zwangerschap kan je terecht voor begeleiding om klachten te voorkomen of vroegtijdig aan te pakken. We werken aan bewustwording en controle van de bekkenbodemspieren en bereiden je voor op de bevalling, met uitleg over arbeid, weeën en hoe je je lichaam hierbij kan ondersteunen. Dit kan individueel of samen met je partner.',
      'Na de bevalling begeleiden we je herstel op jouw tempo. Samen werken we aan een veilige opbouw, afgestemd op jouw lichaam en doelen — van comfortabel bewegen in het dagelijks leven tot een terugkeer naar sport.',
    ],
  },
  {
    imageSrc: expertise5,
    imageAlt: '',
    number: '03',
    title: 'Orthopedische revalidatie',
    description:
      'Na een operatie, blessure of lange periode van klachten begeleiden we je stap voor stap naar herstel, aangepast aan jouw lichaam en tempo.',
    backParagraphs: [
      'Orthopedische revalidatie ondersteunt je herstel na een operatie, blessure of ongeval. We begeleiden je stap voor stap in het terug opbouwen van mobiliteit, kracht en vertrouwen in bewegen. Alles gebeurt op jouw tempo en wordt afgestemd op jouw mogelijkheden en persoonlijke doelen.',
      'In de eerste weken na een ingreep, of wanneer verplaatsen nog moeilijk is, zijn huisbezoeken mogelijk zodat de revalidatie vlot en comfortabel kan starten in je eigen omgeving.',
      'Voorbeelden van klachten of ingrepen: meniscusoperatie, kruisbandreconstructie, heup-, schouder- of knieprothese, enkelverstuiking of -breuk, schouderproblemen (zoals rotator cuff letsel) of herstel na fracturen en sportblessures.',
    ],
  },
  {
    imageSrc: expertise3,
    imageAlt: '',
    number: '04',
    title: 'Algemene kinesitherapie',
    description:
      'Algemene kinesitherapie voor spier- en gewrichtsklachten, met oefentherapie, manuele therapie en dry needling.',
    backParagraphs: [
      'Algemene kinesitherapie helpt bij spier- en gewrichtsklachten zoals pijn, stijfheid of overbelasting, na een blessure, operatie of bij langdurige klachten.',
      'De behandeling wordt afgestemd op jouw noden en bestaat vaak uit oefentherapie om kracht, controle en beweeglijkheid stap voor stap op te bouwen. Indien nodig kunnen ook manuele therapie en dry needling worden ingezet.',
      'Het doel is om je opnieuw vlot en zo comfortabel mogelijk te laten bewegen in het dagelijks leven, werk of sport, met aandacht voor herstel en het voorkomen van terugkerende klachten.',
    ],
  },
];

const reviewData = [
  {
    quote: 'De zorg die ik bij Cocon ontving was ongekend. Ze namen de tijd om mijn behoeften echt te begrijpen en stelden een behandelplan op dat werkte voor mijn lichaam en mijn leven.',
    authorName: 'Sophie M.',
    authorRole: 'Patiënt',
  },
  {
    quote: 'Professionele begeleiding en een warme aanpak. Ik voelde me van begin tot eind in goede handen.',
    authorName: 'Marc D.',
    authorRole: 'Patiënt',
  },
  {
    quote: 'Na mijn zwangerschap heeft de perinatale kinesitherapie me enorm geholpen. Een echte aanrader.',
    authorName: 'Emma V.',
    authorRole: 'Patiënt',
  },
];
---

<BaseLayout
  title="Home"
  description="Cocon is een kinesitherapiepraktijk in Kapelle-op-den-Bos, gespecialiseerd in bekkenbodemtherapie, zwangerschapsbegeleiding, revalidatie en algemene klachten."
  isHome
>
  <Hero
    announcementEnabled={settings.heroAnnouncementEnabled}
    announcementText={settings.heroAnnouncementText}
  />
  <main id="content-after-hero" class="main-with-ellipses">
    <div class="expertise-ellipses" aria-hidden="true">
      <img class="expertise-ellipses__left" src="/images/ellipse-left.svg" alt="" width="752" height="1025" loading="lazy" />
      <img class="expertise-ellipses__right" src="/images/ellipse-right.svg" alt="" width="850" height="1159" loading="lazy" />
    </div>
    <div class="container-content pt-[6.25rem] pb-24 md:pb-32 expertise-content-on-top">
      <ExpertisesCarousel cards={expertisesCards} class="fade-in" />
    </div>
  </main>
  <AfspraakCta class="fade-in" />
  <PraktijkSection class="fade-in" />
  <div class="container-content pt-16 pb-24 md:pt-20 md:pb-32 fade-in">
    <ReviewSection reviews={reviewData} ctaHref="/contact/" />
  </div>
</BaseLayout>
