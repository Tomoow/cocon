---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import SectionHeading from '../components/SectionHeading.astro';
import SpecialtyCard from '../components/SpecialtyCard.astro';
import zaakvoersterImage from '../assets/images/about/zaakvoerster.png';
import { Baby, Activity, Users } from '@lucide/astro';

const specialiteiten = [
  {
    title: 'Prenatale kiné',
    description: 'Tijdens je zwangerschap ondersteun ik je met ademhalingsoefeningen, bekkenbodemreëducatie en voorbereiding op de bevalling. We werken aan klachten zoals urineverlies en bekkenpijn, en aan preventie van postnatale klachten.',
    icon: Baby,
  },
  {
    title: 'Postnatale kiné',
    description: 'Na de bevalling helpen we je lichaam herstellen met bekkenbodemtherapie en oefentherapie. We bouwen je core stability weer op en gaan rug- en bekkenklachten gericht te lijf.',
    icon: Activity,
  },
  {
    title: 'Voorbereiding op bevalling',
    description: 'Samen met je partner bereiden we de bevalling voor: hoe je weeën opvangt, welke rol je partner kan spelen tijdens de arbeid, ademhalingsoefeningen en perstechniek.',
    icon: Users,
  },
];
---

<BaseLayout title="Over ons" description="Alles wat je moet weten over Cocon. Ontmoet Lynn en ontdek onze specialiteiten.">
  <main class="container-content over-ons-page">
    <SectionHeading
      title="Over ons"
      subtitle="Alles wat je moet weten over Cocon"
      id="over-ons-heading"
      class="over-ons-page__heading"
    />

    <section class="meet-lynn" aria-labelledby="meet-lynn-title">
      <div class="meet-lynn__content">
        <span class="meet-lynn__badge">Oprichtster van Cocon</span>
        <h2 class="meet-lynn__title" id="meet-lynn-title">Ontmoet Lynn</h2>
        <div class="meet-lynn__text">
          <p>Ik ben Lynn Beunnens, kinesitherapeut met meer dan vijf jaar ervaring en de gedreven kracht achter deze praktijk. Met passie voor mijn vak help ik mensen van alle leeftijden op weg naar een sterker, gezonder en evenwichtiger lichaam.</p>
          <p>Mijn expertise ligt vooral in pelvische reëducatie en perinatale kinesitherapie, gespecialiseerde zorg die zich richt op de ondersteuning van het bekkengebied vóór, tijdens en na de zwangerschap, én bij klachten in het kleine bekken. Hiervoor heb ik uitgebreid bijgeschoold om je met kennis, zorg en toewijding te begeleiden tijdens elke stap van jouw hersteltraject.</p>
        </div>
      </div>
      <div class="meet-lynn__image-wrap">
        <div class="meet-lynn__ellipse" aria-hidden="true"></div>
        <Image
          src={zaakvoersterImage}
          alt="Lynn Beunnens, oprichtster van Cocon"
          width={400}
          height={400}
          format="webp"
          widths={[280, 360, 400]}
          sizes="(max-width: 767px) 280px, (max-width: 1199px) 360px, 400px"
          loading="eager"
          class="meet-lynn__image"
        />
      </div>
    </section>

    <section class="specialiteiten-section" aria-labelledby="specialiteiten-heading">
      <div class="specialiteiten-section__bg">
        <SectionHeading
          title="Specialisatie"
          subtitle="Mijn focus"
          id="specialiteiten-heading"
          class="specialiteiten-section__heading"
        />
        <div class="specialiteiten-grid">
          {specialiteiten.map((item) => {
            const Icon = item.icon;
            return (
              <SpecialtyCard title={item.title} description={item.description}>
                <Icon slot="icon" size={32} />
              </SpecialtyCard>
            );
          })}
        </div>
        <div class="specialiteiten-carousel" aria-label="Specialisatie carousel">
          <div class="specialiteiten-carousel__track" tabindex="0">
            {specialiteiten.map((item) => {
              const Icon = item.icon;
              return (
                <div class="specialiteiten-carousel__slide">
                  <SpecialtyCard title={item.title} description={item.description}>
                    <Icon slot="icon" size={32} />
                  </SpecialtyCard>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .over-ons-page {
    padding-top: 8rem;
    padding-bottom: 4rem;
  }

  @media (min-width: 768px) {
    .over-ons-page {
      padding-top: 10rem;
      padding-bottom: 5rem;
    }
  }

  .over-ons-page__heading {
    margin-bottom: 2.5rem;
  }

  @media (min-width: 768px) {
    .over-ons-page__heading {
      margin-bottom: 3rem;
    }
  }

  /* ------------------------------------------------------------------- Meet Lynn */
  .meet-lynn {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
    margin-bottom: 4rem;
  }

  @media (min-width: 1024px) {
    .meet-lynn {
      flex-direction: row;
      gap: 2.5rem;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 5rem;
    }
  }

  .meet-lynn__content {
    max-width: 36rem;
    font-family: 'Raleway', sans-serif;
  }

  @media (min-width: 1024px) {
    .meet-lynn__content {
      flex: 1 1 50%;
      order: 1;
    }
  }

  .meet-lynn__badge {
    display: inline-block;
    font-size: 0.9375rem;
    font-weight: 400;
    color: var(--color-primary);
    background: var(--color-background-muted-alt);
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    margin-bottom: 1rem;
  }

  .meet-lynn__title {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-primary);
    margin: 0 0 1rem;
    line-height: 1.25;
  }

  @media (min-width: 768px) {
    .meet-lynn__title {
      font-size: 1.5rem;
    }
  }

  .meet-lynn__text {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-text-primary);
    line-height: 1.625;
  }

  .meet-lynn__text p {
    margin: 0 0 1rem;
  }

  .meet-lynn__text p:last-child {
    margin-bottom: 0;
  }

  .meet-lynn__image-wrap {
    position: relative;
    flex-shrink: 0;
    width: 100%;
    max-width: 280px;
  }

  @media (min-width: 768px) {
    .meet-lynn__image-wrap {
      max-width: 360px;
    }
  }

  @media (min-width: 1024px) {
    .meet-lynn__image-wrap {
      max-width: 400px;
      order: 2;
    }
  }

  .meet-lynn__ellipse {
    position: absolute;
    width: 100%;
    padding-bottom: 100%;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%) rotate(60deg);
    background: var(--color-background-muted-alt);
    border-radius: 50%;
    z-index: 0;
  }

  .meet-lynn__image {
    position: relative;
    z-index: 1;
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 50%;
    display: block;
  }

  /* ----------------------------------------------------------- Specialiteiten */
  .specialiteiten-section {
    width: 100%;
  }

  .specialiteiten-section__bg {
    background: rgba(239, 240, 235, 0.5);
    margin-inline: calc(-1 * var(--spacing-container-mobile));
    padding: 2.5rem var(--spacing-container-mobile) 3rem;
    border-radius: 0;
  }

  @media (min-width: 768px) {
    .specialiteiten-section__bg {
      margin-inline: calc(-1 * var(--spacing-container-tablet));
      padding: 3rem var(--spacing-container-tablet) 4rem;
    }
  }

  @media (min-width: 1200px) {
    .specialiteiten-section__bg {
      margin-inline: calc(-1 * var(--spacing-container-desktop));
      padding: 5rem var(--spacing-container-desktop) 5rem;
    }
  }

  .specialiteiten-section__heading {
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .specialiteiten-section__heading {
      margin-bottom: 2.5rem;
    }
  }

  /* Desktop: grid 3 columns */
  .specialiteiten-grid {
    display: none;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: var(--width-content-max);
    margin-inline: auto;
  }

  @media (min-width: 1000px) {
    .specialiteiten-grid {
      display: grid;
    }
  }

  /* Mobile/tablet: horizontal scroll carousel with peek */
  .specialiteiten-carousel {
    display: block;
    overflow: visible;
  }

  @media (min-width: 1000px) {
    .specialiteiten-carousel {
      display: none;
    }
  }

  .specialiteiten-carousel__track {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    padding-block: 0.5rem 1rem;
    padding-inline: 0;
    scrollbar-width: none;
  }

  .specialiteiten-carousel__track::-webkit-scrollbar {
    display: none;
  }

  .specialiteiten-carousel__slide {
    flex: 0 0 min(85%, 320px);
    scroll-snap-align: start;
    min-width: 0;
  }

  .specialiteiten-carousel__slide :global(.specialty-card) {
    height: 100%;
  }
</style>
