---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Button from '../components/Button.astro';
import BanknoteArrowDown from '@lucide/astro/icons/banknote-arrow-down';
import Hospital from '@lucide/astro/icons/hospital';
import IdCard from '@lucide/astro/icons/id-card';
import CreditCard from '@lucide/astro/icons/credit-card';
import OctagonX from '@lucide/astro/icons/octagon-x';
import Info from '@lucide/astro/icons/info';
import X from '@lucide/astro/icons/x';
import ArrowUpRight from '@lucide/astro/icons/arrow-up-right';

// 3 tarieven cards. The middle one (Specialisatie) is highlighted.
const tarievenCards = [
  {
    number: '01',
    badge: 'Op voorschrift',
    title: 'Algemene kinesitherapie',
    description: 'Voor rug-, nek-, schouder-, sport- en revalidatieklachten ook manuele therapie.',
    rows: [
      { label: 'Eerste behandeling', duration: '45 min', price: '€55' },
      { label: 'Vervolg behandelingen', duration: '30 min', price: '€37' },
    ],
    cta: { label: 'Online afspraak maken', href: '/afspraak', showArrow: true },
    highlighted: false,
  },
  {
    number: '02',
    badge: 'Op voorschrift',
    title: 'Bekkenbodemtherapie',
    description: 'Pelvische reëducatie en perinatale kinesitherapie.',
    rows: [
      { label: 'Eerste behandeling', duration: '45 min', price: '€60' },
      { label: 'Vervolg behandelingen', duration: '30 min', price: '€40' },
    ],
    cta: { label: 'Online afspraak maken', href: '/afspraak', showArrow: true },
    highlighted: true,
    highlightLabel: 'Specialisatie',
  },
  {
    number: '03',
    badge: 'Op voorschrift',
    title: 'Huisbezoek',
    description: 'Wanneer verplaatsen niet evident is. Online boeken niet mogelijk, bel om in te plannen.',
    rows: [
      { label: 'Alle huisbezoeken', duration: '30 min', price: '€45' },
    ],
    cta: { label: 'Bel +32 470 00 00 00', href: 'tel:+32470000000', showArrow: false },
    highlighted: false,
  },
];

// Insurance comparison data shown in the verzekeringen dialog.
type InsuranceTone = 'basis' | 'ruim' | 'neutral';

interface Insurance {
  name: string;
  type: string;
  period: string;
  periodLabel: string;
  tag: string;
  tone: InsuranceTone;
}

const insurances: Insurance[] = [
  {
    name: 'DKV Hospi Essential / Comfort',
    type: 'Privéverzekeraar — basis & comfort',
    period: '30 / 90 dagen',
    periodLabel: 'voor / na opname',
    tag: 'basis',
    tone: 'basis',
  },
  {
    name: 'DKV Hospi Premium+',
    type: 'Privéverzekeraar — premium, volledig',
    period: '60 / 180 dagen',
    periodLabel: 'voor / na opname',
    tag: 'ruim',
    tone: 'ruim',
  },
  {
    name: 'Helan Hospitalia Smart',
    type: 'Ziekenfonds — basisformule',
    period: '30 / 90 dagen',
    periodLabel: 'voor / na opname',
    tag: 'basis · max 20 kinesessies',
    tone: 'basis',
  },
  {
    name: 'Helan Hospitalia Care / Plus',
    type: 'Ziekenfonds — comfort & premium',
    period: '60 / 180 dagen',
    periodLabel: 'voor / na opname',
    tag: 'ruim · max 45 kinesessies',
    tone: 'ruim',
  },
  {
    name: 'NZVL HospiPlus',
    type: 'Ziekenfonds — comfortformule',
    period: '60 / 180 dagen',
    periodLabel: 'voor / na opname',
    tag: 'ruim · max €500/jaar kine',
    tone: 'ruim',
  },
  {
    name: 'Via werkgever (groepspolis)',
    type: 'Collectieve polis — sterk variabel',
    period: '30–180 dagen',
    periodLabel: 'voor / na opname',
    tag: 'check je HR of polis',
    tone: 'neutral',
  },
];
---

<BaseLayout title="Tarieven & info" description="Tarieven voor algemene kinesitherapie, bekkenbodemtherapie en huisbezoeken bij Cocon. Praktische info over terugbetalingen, afspraken en betalingen.">
  <div class="page-header container-content">
    <SectionHeading
      title="Tarieven"
      subtitle=""
      align="center"
    />
    <p class="page-header__lead">
      Cocon is een <strong>gedeconventioneerde</strong> praktijk, bij verhoogde tegemoetkoming hanteren wij de
      <a href="https://www.riziv.fgov.be/nl/professionals/individuele-zorgverleners/kinesitherapeuten/kinesitherapieverstrekkingen-vaste-remgelden" target="_blank" rel="noopener noreferrer">prijzen van het RIZIV</a>.
    </p>
  </div>

  <section class="tarieven-section container-content fade-in" aria-labelledby="tarieven-heading">
    <h2 id="tarieven-heading" class="sr-only">Onze tarieven</h2>
    <ul class="tarieven-grid" role="list">
      {tarievenCards.map((card) => (
        <li class:list={['tarieven-card', card.highlighted && 'tarieven-card--highlighted']}>
          {card.highlighted && card.highlightLabel && (
            <span class="tarieven-card__pill">{card.highlightLabel}</span>
          )}
          <div class="tarieven-card__top">
            <div class="tarieven-card__meta">
              <span class="tarieven-card__number" aria-hidden="true">
                <span class="tarieven-card__number-dot" />
                <span>{card.number}</span>
              </span>
              <span class="tarieven-card__badge">{card.badge}</span>
            </div>
            <h3 class="tarieven-card__title">{card.title}</h3>
            <p class="tarieven-card__description">{card.description}</p>
          </div>
          <div class="tarieven-card__bottom">
            <ul class="tarieven-card__rows" role="list">
              {card.rows.map((row) => (
                <li class="tarieven-card__row">
                  <div class="tarieven-card__row-text">
                    <span class="tarieven-card__row-label">{row.label}</span>
                    <span class="tarieven-card__row-duration">{row.duration}</span>
                  </div>
                  <span class="tarieven-card__row-price">
                    {row.price}<span class="tarieven-card__row-star" aria-hidden="true">*</span>
                  </span>
                </li>
              ))}
            </ul>
            <p class="tarieven-card__disclaimer">
              <span class="tarieven-card__disclaimer-star" aria-hidden="true">*</span> Je mutualiteit betaalt hier nog een deel van terug
            </p>
            <Button href={card.cta.href} showArrow={card.cta.showArrow} class="tarieven-card__cta">
              {card.cta.label}
            </Button>
          </div>
        </li>
      ))}
    </ul>

    <aside class="cancel-banner" role="note" aria-label="Annulatievoorwaarden">
      <span class="cancel-banner__icon" aria-hidden="true">
        <OctagonX class="size-5" />
      </span>
      <p class="cancel-banner__text">
        Annuleer minstens 24 uur op voorhand zodat we tijdig iemand anders kunnen inplannen. Anders wordt de sessie aangerekend.
      </p>
    </aside>
  </section>

  <section class="info-section container-content fade-in" aria-labelledby="info-heading">
    <SectionHeading
      title="Praktische informatie"
      subtitle="Handig om te weten hoe wij te werk gaan"
      id="info-heading"
      align="center"
    />
    <ul class="info-grid" role="list">
      <!-- 1. Terugbetalingen via je mutualiteit -->
      <li class="info-card">
        <div class="info-card__head">
          <BanknoteArrowDown class="info-card__icon size-6" aria-hidden="true" />
          <h3 class="info-card__title">
            Terugbetalingen via je mutualiteit
            <span class="info-card__star" aria-hidden="true">*</span>
          </h3>
        </div>
        <div class="info-card__rich">
          <p>
            Na <strong>je laatste sessie</strong> (vroeger kan ook indien gewenst) krijg je van ons een <strong>getuigschrift</strong> dat je opstuurt naar je mutualiteit of post in hun brievenbus.
          </p>
          <p class="info-card__note">
            → Heb je recht op een <a href="https://www.riziv.fgov.be/nl/thema-s/verzorging-kosten-en-terugbetaling/financiele-toegankelijkheid/de-verhoogde-tegemoetkoming" target="_blank" rel="noopener noreferrer">verhoogde tegemoetkoming</a>? Dan passen wij het lagere <a href="https://www.riziv.fgov.be/nl/professionals/individuele-zorgverleners/kinesitherapeuten/kinesitherapieverstrekkingen-vaste-remgelden" target="_blank" rel="noopener noreferrer">RIZIV-tarief</a> toe.
          </p>
        </div>
      </li>

      <!-- 2. Terugbetalingen via je verzekering — clickable, opens dialog -->
      <li class="info-card info-card--clickable">
        <div class="info-card__head">
          <Hospital class="info-card__icon size-6" aria-hidden="true" />
          <h3 class="info-card__title">
            Terugbetalingen via je verzekering
            <span class="info-card__star" aria-hidden="true">*</span>
          </h3>
        </div>
        <p class="info-card__body">
          Voor- en nazorgkine kan dikwijls extra terugbetaald worden via je <strong>hospitalisatieverzekering</strong> (= voor en na een ziekenhuisopname zoals bij een operatie of bevalling).
        </p>
        <button
          type="button"
          class="info-card__cta"
          data-open-dialog="verzekeringen-dialog"
          aria-haspopup="dialog"
          aria-controls="verzekeringen-dialog"
        >
          <span>Bekijk populaire polissen</span>
          <ArrowUpRight class="size-4" aria-hidden="true" />
        </button>
      </li>

      <!-- 3. Wat breng je mee -->
      <li class="info-card">
        <div class="info-card__head">
          <IdCard class="info-card__icon size-6" aria-hidden="true" />
          <h3 class="info-card__title">Wat breng je mee</h3>
        </div>
        <ul class="info-card__list">
          <li>Identiteitskaart</li>
          <li>Doktersvoorschrift</li>
          <li>Eventuele medische verslagen</li>
          <li>Comfortabele kledij</li>
        </ul>
      </li>

      <!-- 4. Betaalmogelijkheden -->
      <li class="info-card">
        <div class="info-card__head">
          <CreditCard class="info-card__icon size-6" aria-hidden="true" />
          <h3 class="info-card__title">Betaalmogelijkheden</h3>
        </div>
        <ul class="info-card__list">
          <li>Payconiq</li>
          <li>Cash (maar liever niet)</li>
        </ul>
      </li>
    </ul>

  </section>

  <dialog id="verzekeringen-dialog" class="verz-dialog" aria-labelledby="verz-dialog-title">
    <div class="verz-dialog__inner">
      <header class="verz-dialog__header">
        <div class="verz-dialog__heading">
          <p class="verz-dialog__eyebrow">Populaire hospitalisatieverzekeringen</p>
          <h2 class="verz-dialog__title" id="verz-dialog-title">Voor- en nazorgperiode</h2>
        </div>
        <button type="button" class="verz-dialog__close" data-close-dialog aria-label="Sluiten">
          <X class="size-5" aria-hidden="true" />
        </button>
      </header>

      <ul class="verz-grid" role="list">
        {insurances.map((ins) => (
          <li class="verz-card">
            <h3 class="verz-card__name">{ins.name}</h3>
            <div class="verz-card__period">
              <span class="verz-card__period-value">{ins.period}</span>
              <span class="verz-card__period-label">{ins.periodLabel}</span>
            </div>
          </li>
        ))}
      </ul>

      <p class="verz-dialog__note">
        <Info class="size-4 verz-dialog__note-icon" aria-hidden="true" />
        <span>
          Dit zijn <strong>indicatieve voorbeelden</strong>, exacte voorwaarden kunnen nog veranderen en zijn mogelijks niet meer up to date. Raadpleeg daarom altijd je eigen verzekeringspolis voor de meest actuele en accurate informatie.
        </span>
      </p>
    </div>
  </dialog>
</BaseLayout>

<script>
  // Verzekeringen dialog open/close
  const dialog = document.getElementById('verzekeringen-dialog') as HTMLDialogElement | null;
  if (dialog) {
    document.querySelectorAll<HTMLElement>('[data-open-dialog="verzekeringen-dialog"]').forEach((btn) => {
      btn.addEventListener('click', () => dialog.showModal());
    });
    dialog.querySelectorAll<HTMLElement>('[data-close-dialog]').forEach((btn) => {
      btn.addEventListener('click', () => dialog.close());
    });
    // Close on backdrop click — when click target is the dialog itself (the backdrop area)
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) {
        const r = dialog.getBoundingClientRect();
        const inside =
          e.clientX >= r.left && e.clientX <= r.right &&
          e.clientY >= r.top && e.clientY <= r.bottom;
        if (!inside) dialog.close();
      }
    });
  }
</script>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Page header — Tarieven title with bold lead paragraph and RIZIV link below */
  .page-header {
    padding-top: 8.5rem;
    padding-bottom: 1.5rem;
  }

  /* Tighten gap between SectionHeading and lead paragraph */
  .page-header :global(.section-heading) {
    margin-bottom: 0.5rem;
  }

  @media (min-width: 768px) {
    .page-header {
      padding-top: 10.5rem;
    }
  }

  .page-header__lead {
    max-width: 56rem;
    margin: 0 auto;
    text-align: center;
    color: var(--color-text-secondary);
    font-family: 'Raleway', sans-serif;
    font-size: 1.125rem;
    line-height: 1.5;
  }

  @media (min-width: 768px) {
    .page-header__lead {
      font-size: 1.25rem;
      line-height: 1.62;
    }
  }

  .page-header__lead strong {
    font-weight: 700;
    color: var(--color-text-secondary);
  }

  .page-header__lead a {
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .page-header__lead a:hover {
    color: var(--color-primary);
  }

  /* ---------- Tarieven cards ---------- */
  .tarieven-section {
    padding-block: 2.5rem 4rem;
  }

  @media (min-width: 768px) {
    .tarieven-section {
      padding-block: 3rem 6rem;
    }
  }

  .tarieven-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: stretch;
  }

  @media (min-width: 1024px) {
    .tarieven-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .tarieven-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border: 1px solid #dcdcdc;
    border-radius: 1.25rem;
    overflow: visible;
    font-family: 'Raleway', sans-serif;
  }

  .tarieven-card--highlighted {
    background: #f2f5f1;
    border-color: var(--color-primary);
  }

  /* "Specialisatie" pill — sits on top edge of the highlighted card */
  .tarieven-card__pill {
    position: absolute;
    top: -0.6875rem; /* -11px */
    left: 1.4375rem; /* 23px */
    background: linear-gradient(180deg, var(--color-primary) 0%, #004d33 100%);
    color: var(--color-white);
    font-size: 0.875rem;
    line-height: 1;
    padding: 0.25rem 0.5rem;
    border-radius: 0.5rem;
    font-weight: 400;
  }

  /* Top section: meta row + title + description */
  .tarieven-card__top {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2.5rem 1.5rem 1.5rem;
  }

  .tarieven-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .tarieven-card__number {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--color-text-primary);
    font-size: 1rem;
    line-height: 1;
    letter-spacing: 0.025em;
  }

  /* Brand-skewed orange dot before the number */
  .tarieven-card__number-dot {
    display: inline-block;
    width: 0.5rem;
    height: 0.625rem;
    background-color: var(--color-accent);
    border-radius: 50%;
    transform: rotate(43.62deg);
  }

  .tarieven-card__badge {
    color: #4a564e;
    font-size: 1rem;
    line-height: 1;
    letter-spacing: 0.025em;
  }

  .tarieven-card__title {
    margin: 0;
    font-family: 'Spectral', serif;
    font-weight: 400; /* regular per design */
    font-size: 2rem; /* 32px */
    letter-spacing: -2px;
    line-height: 1.125; /* ~36px */
    color: var(--color-primary);
  }

  .tarieven-card__description {
    margin: 0;
    font-size: 1rem;
    line-height: 1.6875;
    color: var(--color-primary);
  }

  /* Bottom section: pricing rows + CTA. flex:1 so pricing pushes the CTA down to align across cards */
  .tarieven-card__bottom {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 1.5rem;
    margin-top: auto;
  }

  .tarieven-card__rows {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .tarieven-card__row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border-top: 1px solid #dcdcdc;
    padding-top: 0.875rem;
  }

  .tarieven-card__row-text {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }

  .tarieven-card__row-label {
    font-weight: 500;
    font-size: 1rem;
    line-height: 1.6875;
    color: var(--color-primary);
  }

  .tarieven-card__row-duration {
    font-size: 1rem;
    line-height: 1;
    color: #676767;
  }

  .tarieven-card__row-price {
    flex-shrink: 0;
    font-family: 'Spectral', serif;
    font-weight: 500;
    font-size: 2rem; /* 32px */
    line-height: 1;
    color: var(--color-primary);
  }

  /* Orange asterisk after each price — small relative to the 32px price */
  .tarieven-card__row-star {
    color: #f87626;
    font-family: 'Raleway', sans-serif;
    font-size: 1.125rem; /* 18px against 32px price */
    font-weight: 700;
    line-height: 1;
    vertical-align: top;
    margin-left: 0.125rem;
  }

  /* Disclaimer above the CTA: small grey text, matches Figma 121:6848 */
  .tarieven-card__disclaimer {
    margin: 0;
    color: #676767;
    font-size: 0.875rem; /* 14px per Figma */
    font-weight: 400;
    line-height: 1.4;
  }

  /* Lead asterisk on the disclaimer is larger than the 14px copy for visual weight */
  .tarieven-card__disclaimer-star {
    color: #f87626;
    font-size: 1.125rem; /* 18px against 14px body */
    font-weight: 700;
    line-height: 1;
    margin-right: 0.25rem;
    vertical-align: middle;
  }

  .tarieven-card__cta {
    width: 100%;
  }

  /* ---------- Cancellation banner ---------- */
  .cancel-banner {
    margin-top: 2rem;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background-color: #fef7ed;
    border: 1px solid #fbe0c1;
    border-radius: 0.875rem;
    font-family: 'Raleway', sans-serif;
  }

  @media (min-width: 768px) {
    .cancel-banner {
      align-items: center;
      padding: 1rem 1.5rem;
    }
  }

  .cancel-banner__icon {
    flex-shrink: 0;
    color: #c8531d;
    display: inline-flex;
    align-items: center;
    margin-top: 0.125rem;
  }

  @media (min-width: 768px) {
    .cancel-banner__icon {
      margin-top: 0;
    }
  }

  .cancel-banner__text {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-primary);
  }

  .cancel-banner__text strong {
    font-weight: 600;
  }

  .cancel-banner__accent {
    color: #c8531d;
  }

  /* ---------- Praktische informatie ---------- */
  .info-section {
    padding-block: 2.5rem 5rem;
  }

  @media (min-width: 768px) {
    .info-section {
      padding-block: 3rem 8rem;
    }
  }

  .info-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.375rem;
    align-items: stretch;
  }

  @media (min-width: 768px) {
    .info-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .info-card {
    background: var(--color-white);
    border: 1px solid #dcdcdc;
    border-radius: 1.25rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem; /* 16px per Figma */
    font-family: 'Raleway', sans-serif;
  }

  .info-card__head {
    display: flex;
    align-items: center;
    gap: 0.6875rem; /* 11px */
  }

  .info-card__icon {
    flex-shrink: 0;
    color: var(--color-primary);
  }

  .info-card__title {
    margin: 0;
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.6875;
    color: var(--color-primary);
  }

  /* Orange asterisk used after the "Terugbetalingen" titles */
  .info-card__star {
    color: #f87626;
    font-weight: 700;
    font-size: 1.125rem;
    line-height: 1;
    margin-left: 0.125rem;
  }

  .info-card__title-accent {
    color: #c8531d;
  }

  .info-card__body {
    margin: 0;
    color: #4a564e;
    font-size: 1rem;
    line-height: 1.6875;
  }

  .info-card__body strong {
    font-weight: 600;
    color: #4a564e;
  }

  /* Rich body block — multiple paragraphs (mutualiteit card) */
  .info-card__rich {
    color: #4a564e;
    font-size: 1rem;
    line-height: 1.6875;
    display: flex;
    flex-direction: column;
    gap: 1.0625rem;
  }

  .info-card__rich p {
    margin: 0;
  }

  .info-card__rich strong {
    font-weight: 600;
  }

  .info-card__note {
    font-style: italic;
  }

  .info-card__note a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .info-card__note a:hover {
    color: var(--color-primary);
  }

  /* Tag groups (verzekering card) */
