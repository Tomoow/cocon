---
/**
 * Contact form (placeholder, not wired up).
 * Submission will be implemented later — the submit button is disabled for now.
 */
---

<form class="flex flex-col gap-4 max-w-md" aria-label="Contactformulier">
  <div>
    <label for="contact-name" class="block text-sm font-medium mb-1">Naam</label>
    <input
      id="contact-name"
      type="text"
      name="name"
      autocomplete="name"
      class="w-full rounded border border-gray-300 px-3 py-2"
    />
  </div>

  <div>
    <label for="contact-email" class="block text-sm font-medium mb-1">E-mail</label>
    <input
      id="contact-email"
      type="email"
      name="email"
      autocomplete="email"
      class="w-full rounded border border-gray-300 px-3 py-2"
    />
  </div>

  <div>
    <label for="contact-message" class="block text-sm font-medium mb-1">Bericht</label>
    <textarea
      id="contact-message"
      name="message"
      rows="4"
      class="w-full rounded border border-gray-300 px-3 py-2"
    />
  </div>

  <button
    type="submit"
    disabled
    aria-disabled="true"
    title="Verzenden wordt later toegevoegd"
    class="rounded bg-primary text-white px-4 py-2 font-medium opacity-60 cursor-not-allowed"
  >
    Verstuur
  </button>
</form>
