---
import Button from './Button.astro';
import UserRound from '@lucide/astro/icons/user-round';
import Mail from '@lucide/astro/icons/mail';
import MessageSquare from '@lucide/astro/icons/message-square';
---

<form
  class="contact-form"
  name="contact"
  method="POST"
  action="/thank-you"
  aria-label="Contactformulier"
>
  <div class="contact-form__row">
    <div class="contact-form__field">
      <label for="contact-name" class="contact-form__label">
        Je naam <span class="contact-form__required" aria-hidden="true">*</span>
      </label>
      <div class="contact-form__input-wrap">
        <UserRound class="contact-form__icon size-5" aria-hidden="true" />
        <input
          id="contact-name"
          type="text"
          name="name"
          autocomplete="name"
          required
          class="contact-form__input"
        />
      </div>
    </div>

    <div class="contact-form__field">
      <label for="contact-email" class="contact-form__label">
        E-mail <span class="contact-form__required" aria-hidden="true">*</span>
      </label>
      <div class="contact-form__input-wrap">
        <Mail class="contact-form__icon size-5" aria-hidden="true" />
        <input
          id="contact-email"
          type="email"
          name="email"
          autocomplete="email"
          required
          class="contact-form__input"
        />
      </div>
    </div>
  </div>

  <div class="contact-form__field">
    <label for="contact-message" class="contact-form__label">
      Bericht <span class="contact-form__required" aria-hidden="true">*</span>
    </label>
    <div class="contact-form__input-wrap contact-form__input-wrap--textarea">
      <MessageSquare class="contact-form__icon size-5" aria-hidden="true" />
      <textarea
        id="contact-message"
        name="message"
        rows="4"
        required
        class="contact-form__input contact-form__input--textarea"
      />
    </div>
  </div>

  <div class="contact-form__actions">
    <Button type="submit" showArrow>
      Bericht versturen
    </Button>
  </div>
</form>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    width: 100%;
    font-family: 'Raleway', sans-serif;
  }

  .contact-form__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .contact-form__row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact-form__field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact-form__label {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.25;
  }

  .contact-form__required {
    font-weight: 400;
  }

  .contact-form__input-wrap {
    position: relative;
    display: flex;
    align-items: center;
    background-color: var(--color-white);
    border: 1px solid #c6c6cc;
    border-radius: 0.75rem;
    padding: 0.75rem;
    gap: 0.5rem;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .contact-form__input-wrap:focus-within {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-primary) 18%, transparent);
  }

  .contact-form__input-wrap--textarea {
    align-items: flex-start;
  }

  .contact-form__icon {
    flex-shrink: 0;
    color: #6b7280;
  }

  .contact-form__input {
    flex: 1;
    min-width: 0;
    border: 0;
    outline: 0;
    background: transparent;
    font: inherit;
    font-size: 1rem;
    line-height: 1.25;
    color: var(--color-text-primary);
  }

  .contact-form__input--textarea {
    resize: vertical;
    min-height: 5.5rem;
  }

  .contact-form__actions {
    display: flex;
  }
</style>
