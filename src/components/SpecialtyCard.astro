---
/**
 * SpecialtyCard: simple card with icon, title, description for Over ons Specialiteiten.
 * No flip, no image; used in grid or carousel.
 */
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<article class="specialty-card">
  <div class="specialty-card__icon-wrap" aria-hidden="true">
    <slot name="icon" />
  </div>
  <h3 class="specialty-card__title">{title}</h3>
  <p class="specialty-card__description">{description}</p>
</article>

<style>
  .specialty-card {
    font-family: 'Raleway', sans-serif;
    background: var(--color-surface);
    border-radius: 1.25rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    min-width: 0;
    height: 100%;
  }

  .specialty-card__icon-wrap {
    width: 5rem;
    height: 5rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-background-muted);
    border-radius: 50%;
    color: var(--color-primary);
  }

  .specialty-card__icon-wrap :global(svg) {
    width: 2rem;
    height: 2rem;
  }

  .specialty-card__title {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-primary);
    margin: 0;
    line-height: 1.25;
  }

  .specialty-card__description {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-primary);
    margin: 0;
    line-height: 1.625;
    flex: 1;
  }
</style>
