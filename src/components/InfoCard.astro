---
/**
 * InfoCard: white card with ellipse-clipped image, brand-skewed number badge,
 * Spectral title, description, and a "Meer informatie →" button that flips the
 * card to reveal the detailed prose.
 *
 * Accessibility: this is a DISCLOSURE, not a giant button. The title and
 * description (front) and the title + prose (back) are real, readable text in
 * the a11y tree. The "Meer informatie" / "Terug" controls are real <button>s
 * with aria-expanded; the non-visible face is `inert` so screen readers only
 * ever see the active side. Clicking anywhere on the active face still flips
 * it (mouse/touch convenience) via a single card-level click handler.
 *
 * Figma: 0:648 (desktop grid), 0:1913 (mobile stack).
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import ArrowRight from '@lucide/astro/icons/arrow-right';

interface Props {
  imageSrc: ImageMetadata;
  imageAlt: string;
  number: string;
  title: string;
  description: string;
  /** Prose paragraphs shown on the back of the card after the user flips it.
   *  Each string is rendered as its own <p>. Pass an empty string to insert a
   *  blank line between visual blocks. */
  backParagraphs: string[];
  /** Read-more label override (default Dutch) */
  ctaLabel?: string;
}

const { imageSrc, imageAlt, number, title, description, backParagraphs, ctaLabel = 'Meer informatie' } = Astro.props;

// Unique id so the front control can `aria-controls` the back region. Slug
// from the title + a short build-time suffix to stay unique even if two cards
// share a title.
const slug = title.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
const uid = `${slug || 'card'}-${Math.random().toString(36).slice(2, 7)}`;
const backId = `info-card-back-${uid}`;
// Ids so focusing a card's control also announces its text: the front button
// `aria-describedby` the teaser, and the revealed back heading `aria-describedby`
// the prose — so a screen reader reads the heading AND the description together.
const descId = `info-card-desc-${uid}`;
const proseId = `info-card-prose-${uid}`;
---

<article class="info-card" data-flip-card>
  <div class="info-card__inner">
    <!-- Front face: readable content (title + description) + a real toggle
         button. Clicking anywhere on the face also flips it (mouse/touch),
         handled by the card-level click listener in the script. -->
    <div class="info-card__face info-card__front">
      <div class="info-card__image-wrap">
        <Image
          src={imageSrc}
          alt={imageAlt}
          width={400}
          height={247}
          format="webp"
          widths={[336, 442, 588, 700]}
          sizes="(max-width: 767px) 336px, (max-width: 1199px) 442px, 588px"
          loading="lazy"
          class="info-card__image"
        />
      </div>
      <div class="info-card__body">
        <span class="info-card__number" aria-hidden="true">
          <span class="info-card__number-inner">{number}</span>
        </span>
        <h3 class="info-card__title">{title}</h3>
        <p class="info-card__description" id={descId} set:html={description} />
        <button
          type="button"
          class="info-card__cta"
          data-flip-trigger
          aria-expanded="false"
          aria-controls={backId}
          aria-label={`${ctaLabel} over ${title}`}
          aria-describedby={descId}
        >
          <span>{ctaLabel}</span>
          <ArrowRight class="info-card__cta-icon size-4" aria-hidden="true" />
        </button>
      </div>
    </div>

    <!-- Back face: readable title + prose, plus a real "Terug" button. It's
         `inert` while the front is showing so screen readers only ever see the
         active side. Scrollable body + pinned footer (with a soft fade hint). -->
    <div class="info-card__face info-card__back" id={backId} inert>
      <div class="info-card__back-body">
        <h3 class="info-card__back-title" tabindex="-1" aria-describedby={proseId}>{title}</h3>
        <div class="info-card__back-prose" id={proseId}>
          {backParagraphs.map((paragraph) => (
            <p class="info-card__back-paragraph" set:html={paragraph} />
          ))}
        </div>
      </div>
      <div class="info-card__back-footer">
        <button
          type="button"
          class="info-card__back-cta"
          data-flip-trigger
          aria-expanded="false"
          aria-label={`Terug naar ${title}`}
        >
          Terug
        </button>
      </div>
    </div>
  </div>
</article>

<style>
  .info-card {
    font-family: 'Raleway', sans-serif;
    perspective: 1000px;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  /* Flex chain so the front face fills the grid cell — when one card's
     description is longer, the rest stretch to match (per-row equal height). */
  .info-card__inner {
    position: relative;
    width: 100%;
    flex: 1;
    min-height: 0;
    transition: transform 0.6s ease;
    transform-style: preserve-3d;
    display: flex;
    flex-direction: column;
  }

  .info-card.is-flipped .info-card__inner {
    transform: rotateY(180deg);
  }

  /* Both faces share rounded corners + shadow + white bg */
  .info-card__front,
  .info-card__back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    background: var(--color-surface);
    border-radius: 1.25rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    overflow: hidden;
    cursor: pointer;
    display: flex;
    flex-direction: column;
  }

  /* Front sits in normal flow so it sets card height (and stretches via flex: 1
     to fill any extra space the grid hands us); back is rotated overlay */
  .info-card__front {
    position: relative;
    flex: 1;
  }

  .info-card__back {
    transform: rotateY(180deg);
  }

  /* Explicitly hide the non-visible face from pointer/touch input.
     `backface-visibility: hidden` already hides it visually, but on
     mobile the back face's overflow-y:auto can still claim touch
     events even when it's rotated away — which freezes page scroll
     until the user touches outside the card. Toggling pointer-events
     per flip state guarantees only the visible face responds. */
  .info-card:not(.is-flipped) .info-card__back {
    pointer-events: none;
  }
  .info-card.is-flipped .info-card__front {
    pointer-events: none;
  }

  /* Focus ring on the real toggle buttons (the faces are no longer focusable). */
  .info-card__cta:focus-visible,
  .info-card__back-cta:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: 0.5rem;
  }

  /* The back title is focused programmatically on flip (so a screen reader
     starts reading the revealed content); it's not a tab stop, so no ring. */
  .info-card__back-title:focus {
    outline: none;
  }

  /* Image: top of card, ellipse-clipped via shared clipPath in BaseLayout */
  .info-card__image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 400 / 247;
    flex-shrink: 0;
    clip-path: url(#info-card-ellipse);
    background: var(--color-background-muted);
    overflow: hidden;
  }

  .info-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
    transition: transform 0.4s ease;
  }

  .info-card:not(.is-flipped):hover .info-card__image {
    transform: scale(1.03);
  }

  /* Body: number badge floats absolute, title/desc/cta stacked */
  .info-card__body {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    /* Mobile: padding-top reserves room for the 80×80-bbox badge that straddles
       the image/body boundary; the title starts safely below it. */
    padding: 3.25rem 1.25rem 1.25rem;
    gap: 0.75rem;
    min-width: 0;
  }

  /* Number badge: brand-skewed ellipse straddling image/body boundary.
     Mobile: 52×64 rect → ~80×80 bounding box after rotation, number 16px.
     Desktop (≥768): full 72×88 with 24px number. */
  .info-card__number {
    position: absolute;
    top: -2rem; /* mobile: half the badge height into the image */
    left: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.25rem; /* 52px */
    height: 4rem; /* 64px */
    background: #f5f5f1;
    border-radius: 50%;
    transform: rotate(43.62deg);
    color: var(--color-primary);
    font-weight: 600;
    font-size: 1rem; /* 16px */
    line-height: 1;
  }

  .info-card__number-inner {
    transform: rotate(-43.62deg);
  }

  @media (min-width: 768px) {
    .info-card__body {
      padding: 4rem 1.5rem 1.5rem;
      gap: 1.25rem;
    }
    .info-card__number {
      top: -2.5rem;
      left: 1.5rem;
      width: 4.5rem; /* 72px */
      height: 5.5rem; /* 88px */
      font-size: 1.5rem; /* 24px */
    }
  }

  /* Title — uses shared card-title token */
  .info-card__title {
    font-family: var(--font-card-title-family);
    font-size: var(--font-card-title-size-mobile);
    font-weight: var(--font-card-title-weight);
    letter-spacing: var(--font-card-title-tracking-mobile);
    line-height: var(--font-card-title-line-height);
    color: var(--color-primary);
    margin: 0;
    overflow-wrap: break-word;
    word-break: break-word;
    min-width: 0;
  }

  @media (min-width: 768px) {
    .info-card__title {
      font-size: var(--font-card-title-size);
      letter-spacing: var(--font-card-title-tracking);
    }
  }

  .info-card__description {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-primary);
    line-height: 1.6875;
    margin: 0;
    flex: 1;
  }

  /* Scannability: highlight keywords inside the description with a
     subtle weight bump. Same color (already primary) so the emphasis
     reads without feeling shouty. */
  .info-card__description strong {
    font-weight: 600;
  }

  .info-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    align-self: flex-end;
    margin-top: auto;
    /* Real <button> now — reset the UA chrome, keep the link-like look. */
    border: 0;
    background: none;
    padding: 0;
    cursor: pointer;
    font-family: inherit;
    color: var(--color-primary);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: -0.0195em;
  }

  .info-card__cta-icon {
    transition: transform 0.2s ease-out;
  }

  .info-card__front:hover .info-card__cta-icon {
    transform: translateX(2px);
  }

  /* Back face: a fixed flex column with a scrollable body and a
     pinned footer. The card itself doesn't scroll (overflow:hidden
     from the shared front/back rule above); only the body does. */
  .info-card__back {
    overflow: hidden;
  }

  .info-card__back-body {
    flex: 1;
    /* `min-height: 0` is the canonical fix that lets a flex child
       actually scroll — without it, the child claims its content's
       intrinsic height as min-height and overflow:auto does nothing. */
    min-height: 0;
    overflow-y: auto;
    /* Isolate inner scroll: scrolling inside this area never chains
       to the page. Avoids the iOS quirk where after scrolling a
       nested region the page scroll can briefly feel "locked" until
       the touch context resets. */
    overscroll-behavior: contain;
    padding: 1.5rem 1.25rem 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .info-card__back-footer {
    position: relative;
    flex-shrink: 0;
    padding: 0.75rem 1.25rem 1.5rem;
    background: var(--color-surface);
  }

  /* Soft white fade just above the footer — hints that there's
     scrollable content above. Visible by default; the page script
     (see bottom of file) toggles `.is-back-bottom` on the card when
     the body is scrolled to the bottom or isn't scrollable at all,
     which hides the fade so it doesn't cover the last line of prose. */
  .info-card__back-footer::before {
    content: '';
    position: absolute;
    bottom: 100%;
    left: 0;
    right: 0;
    height: 1.5rem;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0), var(--color-surface));
    pointer-events: none;
    opacity: 1;
    transition: opacity 0.18s ease-out;
  }

  .info-card.is-back-bottom .info-card__back-footer::before {
    opacity: 0;
  }

  .info-card__back-title {
    font-family: var(--font-card-title-family);
    font-size: var(--font-card-title-size-mobile);
    font-weight: var(--font-card-title-weight);
    letter-spacing: var(--font-card-title-tracking-mobile);
    line-height: var(--font-card-title-line-height);
    color: var(--color-primary);
    margin: 0;
  }

  @media (min-width: 768px) {
    .info-card__back-title {
      font-size: var(--font-card-title-size);
      letter-spacing: var(--font-card-title-tracking);
    }
  }

  .info-card__back-prose {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .info-card__back-paragraph {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
  }

  /* Scannability: highlight keywords in the back prose. Back text is
     `--color-text-secondary` by default, so we bump strong to
     `--color-primary` + weight 600 — two cues that compound nicely
     for visitors scanning rather than reading. */
  .info-card__back-paragraph strong {
    font-weight: 600;
    color: var(--color-primary);
  }

  .info-card__back-cta {
    /* Real <button> now — reset the UA chrome. */
    border: 0;
    background: none;
    padding: 0;
    cursor: pointer;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-primary);
  }
</style>

<script>
  // Defer non-critical: Card flip not needed for initial render
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCardFlip);
  } else {
    setTimeout(initCardFlip, 0);
  }

  function initCardFlip() {
    // Apply a card's open/closed state: flip class, aria-expanded on the
    // toggle buttons, and `inert` on the non-visible face so screen readers
    // only ever see the active side. `manageFocus` is true only for the card
    // the user actually toggled, so auto-closing other cards never steals focus.
    function setCardState(card: Element, expanded: boolean, manageFocus: boolean) {
      card.classList.toggle('is-flipped', expanded);
      const front = card.querySelector<HTMLElement>('.info-card__front');
      const back = card.querySelector<HTMLElement>('.info-card__back');
      card.querySelectorAll('[data-flip-trigger]').forEach((el) => {
        (el as HTMLElement).setAttribute('aria-expanded', String(expanded));
      });
      if (!front || !back) return;
      if (expanded) {
        front.setAttribute('inert', '');
        back.removeAttribute('inert');
        // Move focus to the revealed heading so a screen reader starts reading
        // the back content. preventScroll keeps the page from jumping.
        if (manageFocus) {
          back.querySelector<HTMLElement>('.info-card__back-title')?.focus({ preventScroll: true });
        }
      } else {
        back.setAttribute('inert', '');
        front.removeAttribute('inert');
        // Return focus to the front toggle button.
        if (manageFocus) {
          front.querySelector<HTMLElement>('[data-flip-trigger]')?.focus({ preventScroll: true });
        }
      }
    }

    function flipCard(card: Element) {
      const willOpen = !card.classList.contains('is-flipped');
      // Single-open: when opening a card, flip any other open card back first
      // (without stealing focus to it).
      if (willOpen) {
        document.querySelectorAll('[data-flip-card].is-flipped').forEach((other) => {
          if (other !== card) setCardState(other, false, false);
        });
      }
      setCardState(card, willOpen, true);
    }

    document.querySelectorAll('[data-flip-card]').forEach((card) => {
      // One click handler per card: a click anywhere on the active face — incl.
      // the real toggle buttons (whose Enter/Space fire a native click that
      // bubbles here) — flips the card. The inert face can't be clicked, so
      // clicks are naturally scoped to the visible side.
      card.addEventListener('click', () => flipCard(card));

      // Fade visibility: hide the white fade above the footer when the
      // back body is either fully scrolled to the bottom OR not
      // scrollable at all (so the fade doesn't cover the last sentence
      // on short cards).
      const body = card.querySelector<HTMLElement>('.info-card__back-body');
      if (body) {
        const updateFade = () => {
          // 1px slack to account for sub-pixel rounding across devices
          const atBottom = body.scrollHeight - body.scrollTop - body.clientHeight <= 1;
          const notScrollable = body.scrollHeight <= body.clientHeight + 1;
          card.classList.toggle('is-back-bottom', atBottom || notScrollable);
        };
        body.addEventListener('scroll', updateFade, { passive: true });
        window.addEventListener('resize', updateFade);
        // Defer the first measurement until after layout (back-face is
        // absolute-positioned and might not have its final size on the
        // initial paint frame).
        requestAnimationFrame(updateFade);
      }
    });
  }
</script>
