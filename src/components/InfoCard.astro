---
/**
 * InfoCard: white card with ellipse-clipped image, brand-skewed number badge,
 * Spectral title, description, and a "Meer informatie →" link. Clicking the
 * front (anywhere — including the link) flips the card to reveal bullet points.
 *
 * Figma: 0:648 (desktop grid), 0:1913 (mobile stack).
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import ArrowRight from '@lucide/astro/icons/arrow-right';

interface Props {
  imageSrc: ImageMetadata;
  imageAlt: string;
  number: string;
  title: string;
  description: string;
  /** Bullet points shown on the back of the card after the user flips it */
  backBullets: string[];
  /** Read-more label override (default Dutch) */
  ctaLabel?: string;
}

const { imageSrc, imageAlt, number, title, description, backBullets, ctaLabel = 'Meer informatie' } = Astro.props;
---

<article class="info-card" data-flip-card>
  <div class="info-card__inner">
    <!-- Front face: clickable anywhere to flip -->
    <div class="info-card__face info-card__front" data-flip-trigger role="button" tabindex="0" aria-label={`${ctaLabel} over ${title}`} aria-expanded="false">
      <div class="info-card__image-wrap">
        <Image
          src={imageSrc}
          alt={imageAlt}
          width={588}
          height={247}
          format="webp"
          widths={[336, 442, 588, 700]}
          sizes="(max-width: 767px) 336px, (max-width: 1199px) 442px, 588px"
          loading="lazy"
          class="info-card__image"
        />
      </div>
      <div class="info-card__body">
        <span class="info-card__number" aria-hidden="true">
          <span class="info-card__number-inner">{number}</span>
        </span>
        <h3 class="info-card__title">{title}</h3>
        <p class="info-card__description">{description}</p>
        <span class="info-card__cta">
          <span>{ctaLabel}</span>
          <ArrowRight class="info-card__cta-icon size-4" aria-hidden="true" />
        </span>
      </div>
    </div>

    <!-- Back face: clickable anywhere to flip back -->
    <div class="info-card__face info-card__back" data-flip-trigger role="button" tabindex="-1" aria-label="Terug naar voorkant" aria-expanded="true">
      <div class="info-card__back-body">
        <h3 class="info-card__back-title">{title}</h3>
        <ul class="info-card__back-list">
          {backBullets.map((item) => (
            <li class="info-card__back-item">{item}</li>
          ))}
        </ul>
        <span class="info-card__back-cta">Terug</span>
      </div>
    </div>
  </div>
</article>

<style>
  .info-card {
    font-family: 'Raleway', sans-serif;
    perspective: 1000px;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  /* Flex chain so the front face fills the grid cell — when one card's
     description is longer, the rest stretch to match (per-row equal height). */
  .info-card__inner {
    position: relative;
    width: 100%;
    flex: 1;
    min-height: 0;
    transition: transform 0.6s ease;
    transform-style: preserve-3d;
    display: flex;
    flex-direction: column;
  }

  .info-card.is-flipped .info-card__inner {
    transform: rotateY(180deg);
  }

  /* Both faces share rounded corners + shadow + white bg */
  .info-card__front,
  .info-card__back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    background: var(--color-surface);
    border-radius: 1.25rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    overflow: hidden;
    cursor: pointer;
    display: flex;
    flex-direction: column;
  }

  /* Front sits in normal flow so it sets card height (and stretches via flex: 1
     to fill any extra space the grid hands us); back is rotated overlay */
  .info-card__front {
    position: relative;
    flex: 1;
  }

  .info-card__back {
    transform: rotateY(180deg);
  }

  .info-card__front:focus-visible,
  .info-card__back:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* Image: top of card, ellipse-clipped via shared clipPath in BaseLayout */
  .info-card__image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 588 / 247;
    flex-shrink: 0;
    clip-path: url(#info-card-ellipse);
    background: var(--color-background-muted);
    overflow: hidden;
  }

  .info-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
    transition: transform 0.4s ease;
  }

  .info-card:not(.is-flipped):hover .info-card__image {
    transform: scale(1.03);
  }

  /* Body: number badge floats absolute, title/desc/cta stacked */
  .info-card__body {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    /* Mobile: padding-top reserves room for the 80×80-bbox badge that straddles
       the image/body boundary; the title starts safely below it. */
    padding: 3.25rem 1.25rem 1.25rem;
    gap: 0.75rem;
    min-width: 0;
  }

  /* Number badge: brand-skewed ellipse straddling image/body boundary.
     Mobile: 52×64 rect → ~80×80 bounding box after rotation, number 16px.
     Desktop (≥768): full 72×88 with 24px number. */
  .info-card__number {
    position: absolute;
    top: -2rem; /* mobile: half the badge height into the image */
    left: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.25rem; /* 52px */
    height: 4rem; /* 64px */
    background: #f5f5f1;
    border-radius: 50%;
    transform: rotate(43.62deg);
    color: var(--color-primary);
    font-weight: 600;
    font-size: 1rem; /* 16px */
    line-height: 1;
  }

  .info-card__number-inner {
    transform: rotate(-43.62deg);
  }

  @media (min-width: 768px) {
    .info-card__body {
      padding: 4rem 1.5rem 1.5rem;
      gap: 1.25rem;
    }
    .info-card__number {
      top: -2.5rem;
      left: 1.5rem;
      width: 4.5rem; /* 72px */
      height: 5.5rem; /* 88px */
      font-size: 1.5rem; /* 24px */
    }
  }

  /* Title — uses shared card-title token */
  .info-card__title {
    font-family: var(--font-card-title-family);
    font-size: var(--font-card-title-size-mobile);
    font-weight: var(--font-card-title-weight);
    letter-spacing: var(--font-card-title-tracking-mobile);
    line-height: var(--font-card-title-line-height);
    color: var(--color-primary);
    margin: 0;
    overflow-wrap: break-word;
    word-break: break-word;
    min-width: 0;
  }

  @media (min-width: 768px) {
    .info-card__title {
      font-size: var(--font-card-title-size);
      letter-spacing: var(--font-card-title-tracking);
    }
  }

  .info-card__description {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-primary);
    line-height: 1.6875;
    margin: 0;
    flex: 1;
  }

  .info-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    align-self: flex-end;
    margin-top: auto;
    color: var(--color-primary);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: -0.0195em;
    /* Pointer-events: none so it inherits the card's click; visual element only. */
    pointer-events: none;
  }

  .info-card__cta-icon {
    transition: transform 0.2s ease-out;
  }

  .info-card__front:hover .info-card__cta-icon {
    transform: translateX(2px);
  }

  /* Back face */
  .info-card__back {
    overflow: auto;
  }

  .info-card__back-body {
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: 1rem;
  }

  .info-card__back-title {
    font-family: var(--font-card-title-family);
    font-size: var(--font-card-title-size-mobile);
    font-weight: var(--font-card-title-weight);
    letter-spacing: var(--font-card-title-tracking-mobile);
    line-height: var(--font-card-title-line-height);
    color: var(--color-primary);
    margin: 0;
  }

  @media (min-width: 768px) {
    .info-card__back-title {
      font-size: var(--font-card-title-size);
      letter-spacing: var(--font-card-title-tracking);
    }
  }

  .info-card__back-list {
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
  }

  .info-card__back-item {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    padding-left: 1.25rem;
    position: relative;
    margin-bottom: 0.5rem;
  }

  .info-card__back-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 0.35rem;
    height: 0.35rem;
    background: var(--color-accent);
    border-radius: 50%;
  }

  .info-card__back-cta {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-primary);
    margin-top: auto;
    pointer-events: none;
  }
</style>

<script>
  // Defer non-critical: Card flip not needed for initial render
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCardFlip);
  } else {
    setTimeout(initCardFlip, 0);
  }

  function initCardFlip() {
    function flipCard(card: Element) {
      card.classList.toggle('is-flipped');
      const expanded = card.classList.contains('is-flipped');
      const front = card.querySelector('.info-card__front');
      const back = card.querySelector('.info-card__back');
      card.querySelectorAll('[data-flip-trigger]').forEach((el) => {
        (el as HTMLElement).setAttribute('aria-expanded', String(expanded));
      });
      if (front && back) {
        (front as HTMLElement).setAttribute('tabindex', expanded ? '-1' : '0');
        (back as HTMLElement).setAttribute('tabindex', expanded ? '0' : '-1');
        if (expanded) (back as HTMLElement).focus();
      }
    }

    document.querySelectorAll('[data-flip-card]').forEach((card) => {
      card.querySelectorAll('[data-flip-trigger]').forEach((trigger) => {
        trigger.addEventListener('click', (e) => {
          e.preventDefault();
          flipCard(card);
        });
        trigger.addEventListener('keydown', (e) => {
          if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
            e.preventDefault();
            flipCard(card);
          }
        });
      });
    });
  }
</script>
