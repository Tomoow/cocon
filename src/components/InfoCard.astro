---
/**
 * InfoCard: white card with ellipse-clipped image, brand-skewed number badge,
 * Spectral title, description, and a "Meer informatie →" link. Clicking the
 * front (anywhere — including the link) flips the card to reveal bullet points.
 *
 * Figma: 0:648 (desktop grid), 0:1913 (mobile stack).
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import ArrowRight from '@lucide/astro/icons/arrow-right';

interface Props {
  imageSrc: ImageMetadata;
  imageAlt: string;
  number: string;
  title: string;
  description: string;
  /** Prose paragraphs shown on the back of the card after the user flips it.
   *  Each string is rendered as its own <p>. Pass an empty string to insert a
   *  blank line between visual blocks. */
  backParagraphs: string[];
  /** Read-more label override (default Dutch) */
  ctaLabel?: string;
}

const { imageSrc, imageAlt, number, title, description, backParagraphs, ctaLabel = 'Meer informatie' } = Astro.props;
---

<article class="info-card" data-flip-card>
  <div class="info-card__inner">
    <!-- Front face: clickable anywhere to flip -->
    <div class="info-card__face info-card__front" data-flip-trigger role="button" tabindex="0" aria-label={`${ctaLabel} over ${title}`} aria-expanded="false">
      <div class="info-card__image-wrap">
        <Image
          src={imageSrc}
          alt={imageAlt}
          width={588}
          height={247}
          format="webp"
          widths={[336, 442, 588, 700]}
          sizes="(max-width: 767px) 336px, (max-width: 1199px) 442px, 588px"
          loading="lazy"
          class="info-card__image"
        />
      </div>
      <div class="info-card__body">
        <span class="info-card__number" aria-hidden="true">
          <span class="info-card__number-inner">{number}</span>
        </span>
        <h3 class="info-card__title">{title}</h3>
        <p class="info-card__description" set:html={description} />
        <span class="info-card__cta">
          <span>{ctaLabel}</span>
          <ArrowRight class="info-card__cta-icon size-4" aria-hidden="true" />
        </span>
      </div>
    </div>

    <!-- Back face: clickable anywhere to flip back.
         Structure: scrollable body wraps title + prose; Terug lives
         in a pinned footer outside the scroll so the bottom padding
         can't be eaten by scroll mechanics. A soft white fade sits
         just above the footer to hint that there's scrollable content
         above (purely visual; works on every card whether scrollable
         or not). -->
    <div class="info-card__face info-card__back" data-flip-trigger role="button" tabindex="-1" aria-label="Terug naar voorkant" aria-expanded="true">
      <div class="info-card__back-body">
        <h3 class="info-card__back-title">{title}</h3>
        <div class="info-card__back-prose">
          {backParagraphs.map((paragraph) => (
            <p class="info-card__back-paragraph" set:html={paragraph} />
          ))}
        </div>
      </div>
      <div class="info-card__back-footer">
        <span class="info-card__back-cta">Terug</span>
      </div>
    </div>
  </div>
</article>

<style>
  .info-card {
    font-family: 'Raleway', sans-serif;
    perspective: 1000px;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  /* Flex chain so the front face fills the grid cell — when one card's
     description is longer, the rest stretch to match (per-row equal height). */
  .info-card__inner {
    position: relative;
    width: 100%;
    flex: 1;
    min-height: 0;
    transition: transform 0.6s ease;
    transform-style: preserve-3d;
    display: flex;
    flex-direction: column;
  }

  .info-card.is-flipped .info-card__inner {
    transform: rotateY(180deg);
  }

  /* Both faces share rounded corners + shadow + white bg */
  .info-card__front,
  .info-card__back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    background: var(--color-surface);
    border-radius: 1.25rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    overflow: hidden;
    cursor: pointer;
    display: flex;
    flex-direction: column;
  }

  /* Front sits in normal flow so it sets card height (and stretches via flex: 1
     to fill any extra space the grid hands us); back is rotated overlay */
  .info-card__front {
    position: relative;
    flex: 1;
  }

  .info-card__back {
    transform: rotateY(180deg);
  }

  .info-card__front:focus-visible,
  .info-card__back:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* Image: top of card, ellipse-clipped via shared clipPath in BaseLayout */
  .info-card__image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 588 / 247;
    flex-shrink: 0;
    clip-path: url(#info-card-ellipse);
    background: var(--color-background-muted);
    overflow: hidden;
  }

  .info-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
    transition: transform 0.4s ease;
  }

  .info-card:not(.is-flipped):hover .info-card__image {
    transform: scale(1.03);
  }

  /* Body: number badge floats absolute, title/desc/cta stacked */
  .info-card__body {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    /* Mobile: padding-top reserves room for the 80×80-bbox badge that straddles
       the image/body boundary; the title starts safely below it. */
    padding: 3.25rem 1.25rem 1.25rem;
    gap: 0.75rem;
    min-width: 0;
  }

  /* Number badge: brand-skewed ellipse straddling image/body boundary.
     Mobile: 52×64 rect → ~80×80 bounding box after rotation, number 16px.
     Desktop (≥768): full 72×88 with 24px number. */
  .info-card__number {
    position: absolute;
    top: -2rem; /* mobile: half the badge height into the image */
    left: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.25rem; /* 52px */
    height: 4rem; /* 64px */
    background: #f5f5f1;
    border-radius: 50%;
    transform: rotate(43.62deg);
    color: var(--color-primary);
    font-weight: 600;
    font-size: 1rem; /* 16px */
    line-height: 1;
  }

  .info-card__number-inner {
    transform: rotate(-43.62deg);
  }

  @media (min-width: 768px) {
    .info-card__body {
      padding: 4rem 1.5rem 1.5rem;
      gap: 1.25rem;
    }
    .info-card__number {
      top: -2.5rem;
      left: 1.5rem;
      width: 4.5rem; /* 72px */
      height: 5.5rem; /* 88px */
      font-size: 1.5rem; /* 24px */
    }
  }

  /* Title — uses shared card-title token */
  .info-card__title {
    font-family: var(--font-card-title-family);
    font-size: var(--font-card-title-size-mobile);
    font-weight: var(--font-card-title-weight);
    letter-spacing: var(--font-card-title-tracking-mobile);
    line-height: var(--font-card-title-line-height);
    color: var(--color-primary);
    margin: 0;
    overflow-wrap: break-word;
    word-break: break-word;
    min-width: 0;
  }

  @media (min-width: 768px) {
    .info-card__title {
      font-size: var(--font-card-title-size);
      letter-spacing: var(--font-card-title-tracking);
    }
  }

  .info-card__description {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-primary);
    line-height: 1.6875;
    margin: 0;
    flex: 1;
  }

  /* Scannability: highlight keywords inside the description with a
     subtle weight bump. Same color (already primary) so the emphasis
     reads without feeling shouty. */
  .info-card__description strong {
    font-weight: 600;
  }

  .info-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    align-self: flex-end;
    margin-top: auto;
    color: var(--color-primary);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: -0.0195em;
    /* Pointer-events: none so it inherits the card's click; visual element only. */
    pointer-events: none;
  }

  .info-card__cta-icon {
    transition: transform 0.2s ease-out;
  }

  .info-card__front:hover .info-card__cta-icon {
    transform: translateX(2px);
  }

  /* Back face: a fixed flex column with a scrollable body and a
     pinned footer. The card itself doesn't scroll (overflow:hidden
     from the shared front/back rule above); only the body does. */
  .info-card__back {
    overflow: hidden;
  }

  .info-card__back-body {
    flex: 1;
    /* `min-height: 0` is the canonical fix that lets a flex child
       actually scroll — without it, the child claims its content's
       intrinsic height as min-height and overflow:auto does nothing. */
    min-height: 0;
    overflow-y: auto;
    padding: 1.5rem 1.25rem 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .info-card__back-footer {
    position: relative;
    flex-shrink: 0;
    padding: 0.75rem 1.25rem 1.5rem;
    background: var(--color-surface);
  }

  /* Soft white fade just above the footer — hints that there's
     scrollable content above. Visible by default; the page script
     (see bottom of file) toggles `.is-back-bottom` on the card when
     the body is scrolled to the bottom or isn't scrollable at all,
     which hides the fade so it doesn't cover the last line of prose. */
  .info-card__back-footer::before {
    content: '';
    position: absolute;
    bottom: 100%;
    left: 0;
    right: 0;
    height: 1.5rem;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0), var(--color-surface));
    pointer-events: none;
    opacity: 1;
    transition: opacity 0.18s ease-out;
  }

  .info-card.is-back-bottom .info-card__back-footer::before {
    opacity: 0;
  }

  .info-card__back-title {
    font-family: var(--font-card-title-family);
    font-size: var(--font-card-title-size-mobile);
    font-weight: var(--font-card-title-weight);
    letter-spacing: var(--font-card-title-tracking-mobile);
    line-height: var(--font-card-title-line-height);
    color: var(--color-primary);
    margin: 0;
  }

  @media (min-width: 768px) {
    .info-card__back-title {
      font-size: var(--font-card-title-size);
      letter-spacing: var(--font-card-title-tracking);
    }
  }

  .info-card__back-prose {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .info-card__back-paragraph {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
  }

  /* Scannability: highlight keywords in the back prose. Back text is
     `--color-text-secondary` by default, so we bump strong to
     `--color-primary` + weight 600 — two cues that compound nicely
     for visitors scanning rather than reading. */
  .info-card__back-paragraph strong {
    font-weight: 600;
    color: var(--color-primary);
  }

  .info-card__back-cta {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-primary);
    /* Terug lives in the pinned .info-card__back-footer now, which
       is itself a flex sibling — no need for margin-top:auto. */
    pointer-events: none;
  }
</style>

<script>
  // Defer non-critical: Card flip not needed for initial render
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCardFlip);
  } else {
    setTimeout(initCardFlip, 0);
  }

  function initCardFlip() {
    function flipCard(card: Element) {
      card.classList.toggle('is-flipped');
      const expanded = card.classList.contains('is-flipped');
      const front = card.querySelector('.info-card__front');
      const back = card.querySelector('.info-card__back');
      card.querySelectorAll('[data-flip-trigger]').forEach((el) => {
        (el as HTMLElement).setAttribute('aria-expanded', String(expanded));
      });
      if (front && back) {
        (front as HTMLElement).setAttribute('tabindex', expanded ? '-1' : '0');
        (back as HTMLElement).setAttribute('tabindex', expanded ? '0' : '-1');
        if (expanded) (back as HTMLElement).focus();
      }
    }

    document.querySelectorAll('[data-flip-card]').forEach((card) => {
      card.querySelectorAll('[data-flip-trigger]').forEach((trigger) => {
        trigger.addEventListener('click', (e) => {
          e.preventDefault();
          flipCard(card);
        });
        trigger.addEventListener('keydown', (e) => {
          if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
            e.preventDefault();
            flipCard(card);
          }
        });
      });

      // Fade visibility: hide the white fade above the footer when the
      // back body is either fully scrolled to the bottom OR not
      // scrollable at all (so the fade doesn't cover the last sentence
      // on short cards).
      const body = card.querySelector<HTMLElement>('.info-card__back-body');
      if (body) {
        const updateFade = () => {
          // 1px slack to account for sub-pixel rounding across devices
          const atBottom = body.scrollHeight - body.scrollTop - body.clientHeight <= 1;
          const notScrollable = body.scrollHeight <= body.clientHeight + 1;
          card.classList.toggle('is-back-bottom', atBottom || notScrollable);
        };
        body.addEventListener('scroll', updateFade, { passive: true });
        window.addEventListener('resize', updateFade);
        // Defer the first measurement until after layout (back-face is
        // absolute-positioned and might not have its final size on the
        // initial paint frame).
        requestAnimationFrame(updateFade);
      }
    });
  }
</script>
