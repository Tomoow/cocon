---
/**
 * AfspraakModal — pre-opening teaser shown when visitors click any
 * "Afspraak maken" button. Desktop: centered modal with fade+scale.
 * Mobile (<768px): bottom sheet sliding up from the bottom.
 *
 * Intercepts clicks on any link with href="/afspraak" so we don't
 * need to change every CTA on the site. If JS fails to load, the
 * `/afspraak` route is redirected to `/` (see astro.config) so users
 * still land somewhere sensible.
 */
import X from '@lucide/astro/icons/x';
---

<div
  id="afspraak-modal"
  class="afspraak-modal"
  aria-hidden="true"
  inert
  data-afspraak-modal
>
  <div class="afspraak-modal__backdrop" data-afspraak-close></div>

  <div
    class="afspraak-modal__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="afspraak-modal-title"
    aria-describedby="afspraak-modal-body"
    tabindex="-1"
  >
    <button
      type="button"
      class="afspraak-modal__close"
      aria-label="Sluit"
      data-afspraak-close
    >
      <X class="size-5" aria-hidden="true" />
    </button>

    <div class="afspraak-modal__content">
      <h2 id="afspraak-modal-title" class="afspraak-modal__title">
        We openen<br />begin augustus 2026
      </h2>

      <p id="afspraak-modal-body" class="afspraak-modal__text">
        Cocon maakt zich klaar om de deuren te openen. Online een afspraak inplannen kan nog niet, maar wil je nu al een <strong>afspraak voor augustus</strong> vastleggen? Bel of contacteer ons, dan plannen we je alvast in. Ook met vragen over <strong>bekkenbodemtherapie</strong>, <strong>zwangerschapsbegeleiding</strong> of <strong>revalidatie</strong> helpen we je graag verder.
      </p>

      <div class="afspraak-modal__actions">
        <a
          href="/contact/"
          class="afspraak-modal__contact-btn"
          data-umami-event="cta-contact"
          data-umami-event-source="afspraak-modal"
        >
          Contacteer ons
        </a>
        <a
          href="tel:+32456864665"
          class="afspraak-modal__dismiss-btn"
          data-umami-event="cta-phone"
          data-umami-event-source="afspraak-modal"
        >
          Bel 0456 86 46 65
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  /* Container: full-screen overlay; hidden by default via inert+CSS.
     When [data-state="open"], we let the backdrop fade in and the panel slide in. */
  .afspraak-modal {
    position: fixed;
    inset: 0;
    z-index: 200; /* above the header (z-100) */
    display: none;
    align-items: flex-end;
    justify-content: center;
    pointer-events: none;
  }

  .afspraak-modal[data-state='opening'],
  .afspraak-modal[data-state='open'],
  .afspraak-modal[data-state='closing'] {
    display: flex;
    pointer-events: auto;
  }

  /* Desktop: centered modal */
  @media (min-width: 768px) {
    .afspraak-modal {
      align-items: center;
      padding: 1.5rem;
    }
  }

  /* Backdrop ---------------------------------------------------------- */
  .afspraak-modal__backdrop {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.5); /* neutral black at 50% */
    backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity 0.25s ease-out;
  }

  .afspraak-modal[data-state='open'] .afspraak-modal__backdrop {
    opacity: 1;
  }

  /* Panel: bottom sheet on mobile, centered card on desktop --------- */
  .afspraak-modal__panel {
    position: relative;
    /* The script focuses the panel on open (for a11y) — suppress the
       default focus ring on the panel itself since it isn't an
       interactive control. Tab moves on to real interactive elements
       (X, Sluit) which keep their own focus styles. */
    outline: none;
    /* Mobile: full bleed — stretch across the entire viewport, no gaps */
    width: 100%;
    max-width: none;
    max-height: 92dvh;
    overflow-y: auto;
    background-color: #ffffff;
    color: var(--color-primary);
    /* Top corners rounded on mobile sheet */
    border-radius: 1.5rem 1.5rem 0 0;
    padding: 2rem 1.5rem;
    box-shadow: 0 -16px 48px rgba(0, 0, 0, 0.18);
    transform: translateY(100%); /* mobile: starts off-screen below */
    transition: transform 0.32s cubic-bezier(0.32, 0.72, 0.32, 1);
  }

  .afspraak-modal[data-state='open'] .afspraak-modal__panel {
    transform: translateY(0);
  }

  @media (min-width: 768px) {
    .afspraak-modal__panel {
      /* Desktop: constrained, centered card */
      width: 100%;
      max-width: 32rem;
      border-radius: 1.25rem; /* all four corners */
      padding: 2.5rem;
      box-shadow: 0 24px 64px rgba(0, 0, 0, 0.24);
      /* Desktop: fade + scale entrance instead of slide-up */
      transform: translateY(8px) scale(0.96);
      opacity: 0;
      transition:
        transform 0.22s ease-out,
        opacity 0.22s ease-out;
    }
    .afspraak-modal[data-state='open'] .afspraak-modal__panel {
      transform: translateY(0) scale(1);
      opacity: 1;
    }
  }

  /* Close (X) button ------------------------------------------------- */
  .afspraak-modal__close {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 0;
    border-radius: 9999px;
    background: transparent;
    color: var(--color-primary);
    cursor: pointer;
    transition: background-color 0.15s ease;
  }

  .afspraak-modal__close:hover,
  .afspraak-modal__close:focus-visible {
    background-color: rgba(0, 51, 32, 0.08);
  }

  .afspraak-modal__close:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* Content ---------------------------------------------------------- */
  .afspraak-modal__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    font-family: 'Raleway', sans-serif;
  }

  .afspraak-modal__title {
    font-family: 'Spectral', serif;
    font-size: 1.75rem; /* 28px on mobile */
    font-weight: 500;
    letter-spacing: -1px;
    line-height: 1.1;
    color: var(--color-primary);
    margin: 0;
  }

  @media (min-width: 768px) {
    .afspraak-modal__title {
      font-size: 2.25rem; /* 36px on desktop */
      letter-spacing: -1.5px;
    }
  }

  .afspraak-modal__text {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
    margin: 0;
  }

  .afspraak-modal__text strong {
    color: var(--color-primary);
    font-weight: 600;
  }

  .afspraak-modal__actions {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-top: 0.5rem;
  }

  @media (min-width: 480px) {
    .afspraak-modal__actions {
      flex-direction: row;
    }
  }

  /* Primary action — styled like the site's primary button. Plain <a>
     instead of <Button> because the latter doesn't forward data-*
     attributes (needed for Umami tracking). */
  .afspraak-modal__contact-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border: 2px solid var(--color-primary);
    border-radius: 9999px;
    background-color: var(--color-primary);
    color: var(--color-white);
    font-family: 'Raleway', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.25;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.15s ease;
  }

  .afspraak-modal__contact-btn:hover {
    opacity: 0.9;
  }

  .afspraak-modal__contact-btn:active {
    opacity: 0.8;
  }

  .afspraak-modal__contact-btn:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px var(--color-background-default), 0 0 0 4px var(--color-primary);
  }

  /* Secondary action (tel link) — styled like the site's secondary button so
     it visually matches the primary CTA next to it. */
  .afspraak-modal__dismiss-btn {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border: 2px solid var(--color-primary);
    border-radius: 9999px;
    background-color: var(--color-surface, #fff);
    color: var(--color-primary);
    font-family: 'Raleway', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.25;
    cursor: pointer;
    transition: background-color 0.15s ease, opacity 0.15s ease;
  }

  .afspraak-modal__dismiss-btn:hover {
    background-color: var(--color-background-muted);
  }

  .afspraak-modal__dismiss-btn:active {
    background: color-mix(in srgb, var(--color-background-muted) 95%, black);
  }

  .afspraak-modal__dismiss-btn:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px var(--color-primary), 0 0 0 4px var(--color-background-default);
  }

  /* When the modal is open we want the body not to scroll behind it */
  :global(body.afspraak-modal-open) {
    overflow: hidden;
  }
</style>

<script>
  (function () {
    const modal = document.querySelector<HTMLElement>('[data-afspraak-modal]');
    if (!modal) return;

    let lastTrigger: HTMLElement | null = null;
    let closeTimeout: number | null = null;

    function getFocusable(): HTMLElement[] {
      return Array.from(
        modal!.querySelectorAll<HTMLElement>(
          'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'
        )
      ).filter((el) => !el.hasAttribute('inert') && el.offsetParent !== null);
    }

    function open(trigger?: HTMLElement) {
      lastTrigger = trigger ?? null;
      if (closeTimeout != null) {
        window.clearTimeout(closeTimeout);
        closeTimeout = null;
      }

      // Two-step entrance so CSS transitions actually run.
      // Step 1: flip data-state to 'opening' — this changes the container from
      // display:none to display:flex but the panel/backdrop start at their
      // "closed" transform/opacity values.
      modal!.setAttribute('data-state', 'opening');
      modal!.removeAttribute('inert');
      modal!.setAttribute('aria-hidden', 'false');
      document.body.classList.add('afspraak-modal-open');

      // Step 2: force a layout pass, then on the next frame flip to 'open' so
      // the transition has both a starting and an ending value to interpolate.
      // Without this, going from display:none straight to the open transform
      // never animates (the browser has no prior state to interpolate from) —
      // which is why the sheet only slid out but never in.
      void modal!.offsetHeight; // commit the 'opening' layout
      requestAnimationFrame(() => {
        modal!.setAttribute('data-state', 'open');
        // Move focus into the dialog so screen readers announce it and so
        // keyboard users can Escape/Tab to close. We focus the panel
        // itself (tabindex="-1") rather than a button — focusing the
        // Sluit button stacks its always-on border with the focus ring,
        // which reads as a doubled outline. The panel has no visible
        // border so no doubled look, and Tab still walks through the
        // interactive elements in order.
        const panel = modal!.querySelector<HTMLElement>('.afspraak-modal__panel');
        panel?.focus({ preventScroll: true });
      });
    }

    function close() {
      modal!.setAttribute('data-state', 'closing');
      modal!.setAttribute('aria-hidden', 'true');
      modal!.setAttribute('inert', '');
      document.body.classList.remove('afspraak-modal-open');

      // Wait for the panel transition to finish before fully hiding so the user sees the slide-out
      closeTimeout = window.setTimeout(() => {
        modal!.removeAttribute('data-state');
        closeTimeout = null;
      }, 320);

      // Return focus to whatever opened the modal (good for keyboard users)
      lastTrigger?.focus();
      lastTrigger = null;
    }

    // ---- Intercept all "Afspraak maken" links/buttons across the site ----
    function isAfspraakHref(href: string | null): boolean {
      if (!href) return false;
      try {
        const url = new URL(href, window.location.origin);
        // Match /afspraak with or without trailing slash, same-origin only
        return (
          url.origin === window.location.origin &&
          /^\/afspraak\/?$/.test(url.pathname)
        );
      } catch {
        return false;
      }
    }

    // Fire the Umami event ourselves. We stop the click from propagating
    // (below), so Umami never sees it — replicate its data-umami-event-*
    // → eventData extraction so the analytics are unchanged.
    function trackAfspraakEvent(link: HTMLElement) {
      const eventName = link.getAttribute('data-umami-event');
      if (!eventName) return;
      const data: Record<string, string> = {};
      link.getAttributeNames().forEach((name) => {
        const m = name.match(/^data-umami-event-(.+)$/);
        const val = m && link.getAttribute(name);
        if (m && val != null) data[m[1]] = val;
      });
      (window as any).umami?.track?.(eventName, Object.keys(data).length ? data : undefined);
    }

    // Listen on `window` in the CAPTURE phase. This is deliberate: Umami's
    // tracker also hooks link clicks, and for any <a data-umami-event> it
    // records the event and then runs its own `location.href = href` — which
    // preventDefault() cannot cancel. That made the modal flash open and then
    // navigate to /afspraak/ (a 404) on devices where Umami loads (e.g. mobile,
    // or any browser without an ad-blocker). A window-level capture listener
    // runs before Umami's document-level handler, so stopImmediatePropagation()
    // prevents Umami from firing at all.
    window.addEventListener(
      'click',
      (e) => {
        const target = e.target as HTMLElement | null;
        if (!target) return;
        const link = target.closest<HTMLAnchorElement>('a[href]');
        if (!link) return;
        if (!isAfspraakHref(link.getAttribute('href'))) return;
        // Respect modifier-clicks (open in new tab) and middle-clicks
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
        e.preventDefault();
        e.stopImmediatePropagation();
        trackAfspraakEvent(link);
        open(link);
      },
      true
    );

    // ---- Dismissal: backdrop, close button, Escape key ----
    modal.addEventListener('click', (e) => {
      const target = e.target as HTMLElement | null;
      if (target?.closest('[data-afspraak-close]')) {
        e.preventDefault();
        close();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      if (modal.getAttribute('data-state') !== 'open') return;
      close();
    });

    // Focus trap inside the modal while open
    modal.addEventListener('keydown', (e) => {
      if (e.key !== 'Tab') return;
      if (modal.getAttribute('data-state') !== 'open') return;
      const focusables = getFocusable();
      if (!focusables.length) return;
      const first = focusables[0];
      const last = focusables[focusables.length - 1];
      const active = document.activeElement;
      // The panel itself holds focus right after opening (tabindex="-1")
      // but isn't in the focusables list — treat "not in the list" as a
      // boundary too, so Shift+Tab from the panel can't escape into the
      // page behind the backdrop.
      const inList = active instanceof HTMLElement && focusables.includes(active);
      if (e.shiftKey && (active === first || !inList)) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && active === last) {
        e.preventDefault();
        first.focus();
      }
    });
  })();
</script>
