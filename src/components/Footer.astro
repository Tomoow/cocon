---
/**
 * Footer (Figma 110:6385 desktop / 179:1880 mobile):
 *
 *   ┌────────────────────────────── footer__main ──────────────────────────────┐
 *   │  ┌── brand ──┐                        ┌── columns ──────────────────┐    │
 *   │  │  Cocon    │                        │  Menu        Contact         │    │
 *   │  │  logo     │                        │  Home        info@…          │    │
 *   │  │           │                        │  Tarieven    0456…           │    │
 *   │  │  📍 …     │                        │  Over ons    [IG] [FB]       │    │
 *   │  │  📍📍 …    │                        │  FAQ                          │    │
 *   │  │  🏢 …     │                        │  Contact                      │    │
 *   │  └───────────┘                        └──────────────────────────────┘    │
 *   └──────────────────────────────────────────────────────────────────────────┘
 *   ┌─ legal row (no divider above) ───────────────────────────────────────────┐
 *   │  Voorwaarden • Privacy                      © Cocon • Website By Tom L  │
 *   └──────────────────────────────────────────────────────────────────────────┘
 *
 *   Behind everything: footer-image.png on ≥768 / mobile-footer.png on <768,
 *   rendered via ::before at 80% opacity so content keeps full contrast.
 *
 *   footer__main has min-height 650px on desktop (per Figma) so the
 *   landscape illustration has room to breathe under the columns.
 */
import IconButton from './IconButton.astro';
import House from '@lucide/astro/icons/house';
import BadgeEuro from '@lucide/astro/icons/badge-euro';
import Users from '@lucide/astro/icons/users';
import CircleHelp from '@lucide/astro/icons/circle-question-mark';
import MessageCircle from '@lucide/astro/icons/message-circle';
import Phone from '@lucide/astro/icons/phone';
import MapPin from '@lucide/astro/icons/map-pin';
import MapPinned from '@lucide/astro/icons/map-pinned';
import Building2 from '@lucide/astro/icons/building-2';
import Mail from '@lucide/astro/icons/mail';
import Instagram from '@lucide/astro/icons/instagram';
import Facebook from '@lucide/astro/icons/facebook';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const navItems = [
  { href: '/', label: 'Home', icon: House },
  { href: '/tarieven/', label: 'Tarieven & info', icon: BadgeEuro },
  { href: '/over-ons/', label: 'Over ons', icon: Users },
  { href: '/faq/', label: 'FAQ', icon: CircleHelp },
  { href: '/contact/', label: 'Contact', icon: MessageCircle },
];

function isActive(href: string, path: string): boolean {
  if (href === '/') return path === '/' || path === '';
  return path.startsWith(href);
}
---

<footer class="footer" aria-label="Footer">
  <div class="footer__inner container-content">
    <div class="footer__main">
      <!-- Brand column: logo + bedrijfsinfo. No "Bedrijfsinformatie" heading
           per the redesign — the info just sits under the wordmark. -->
      <div class="footer__brand">
        <a href="/" class="footer__logo-link" aria-label="Cocon home">
          <img src="/logo/cocon.svg" alt="" width="500" height="103" class="footer__logo-img" loading="lazy" />
        </a>
        <ul class="footer__list footer__bedrijfsinfo" aria-label="Bedrijfsinformatie">
          <li>
            <span class="footer__link footer__link--text">
              <span class="footer__link-icon" aria-hidden="true">
                <MapPin />
              </span>
              <span class="footer__link-text">
                Mechelseweg 62 <span class="footer__dot" aria-hidden="true" /> 1880 Kapelle-op-den-Bos
              </span>
            </span>
          </li>
          <li>
            <span class="footer__link footer__link--text">
              <span class="footer__link-icon" aria-hidden="true">
                <MapPinned />
              </span>
              <span class="footer__link-text">In het gebouw van Poutrel</span>
            </span>
          </li>
          <li>
            <span class="footer__link footer__link--text">
              <span class="footer__link-icon" aria-hidden="true">
                <Building2 />
              </span>
              <span class="footer__link-text">BE 1004.016.118</span>
            </span>
          </li>
        </ul>
      </div>

      <!-- Right side: Menu + Contact columns -->
      <div class="footer__columns">
        <nav class="footer__block footer__block--menu" aria-label="Menu">
          <h3 class="footer__heading">Menu</h3>
          <ul class="footer__list">
            {navItems.map(({ href, label, icon: Icon }) => {
              const active = isActive(href, currentPath);
              return (
                <li>
                  {active ? (
                    <span class:list={['footer__link', 'footer__link--active']} aria-current="page">
                      <span class="footer__link-icon" aria-hidden="true">
                        <Icon />
                      </span>
                      {label}
                    </span>
                  ) : (
                    <a href={href} class="footer__link">
                      <span class="footer__link-icon" aria-hidden="true">
                        <Icon />
                      </span>
                      {label}
                    </a>
                  )}
                </li>
              );
            })}
          </ul>
        </nav>

        <div class="footer__block footer__block--contact" aria-labelledby="footer-contact">
          <h3 class="footer__heading" id="footer-contact">Contact</h3>
          <ul class="footer__list">
            <li>
              <a
                href="mailto:info@kine-cocon.be"
                class="footer__link"
                data-umami-event="cta-email"
                data-umami-event-source="footer"
              >
                <span class="footer__link-icon" aria-hidden="true">
                  <Mail />
                </span>
                info@kine-cocon.be
              </a>
            </li>
            <li>
              <a
                href="tel:+32456864665"
                class="footer__link"
                data-umami-event="cta-phone"
                data-umami-event-source="footer"
              >
                <span class="footer__link-icon" aria-hidden="true">
                  <Phone />
                </span>
                0456 86 46 65
              </a>
            </li>
          </ul>
          <div class="footer__socials">
            <IconButton
              href="https://www.instagram.com/kine_cocon/"
              label="Instagram"
              variant="primary"
              class="footer__social-btn"
              umamiEvent="cta-social"
              umamiEventNetwork="instagram"
              umamiEventSource="footer"
            >
              <Instagram class="size-5" />
            </IconButton>
            <IconButton
              href="https://facebook.com"
              label="Facebook"
              variant="primary"
              class="footer__social-btn"
              umamiEvent="cta-social"
              umamiEventNetwork="facebook"
              umamiEventSource="footer"
            >
              <Facebook class="size-5" />
            </IconButton>
          </div>
        </div>
      </div>
    </div>

    <div class="footer__legal">
      <div class="footer__legal-links">
        <a href="/voorwaarden/" class="footer__legal-link">Voorwaarden</a>
        <span class="footer__dot" aria-hidden="true" />
        <a href="/privacy/" class="footer__legal-link">Privacy</a>
      </div>
      <div class="footer__legal-copy">
        © Cocon <span class="footer__dot" aria-hidden="true" /> Website By <a href="https://tomlievens.framer.website/" class="footer__legal-link" target="_blank" rel="noopener noreferrer">Tom Lievens</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    /* Cream base — the bg-image (added via ::before) sits on top at 80%
       opacity so the cream still tints through. */
    position: relative;
    isolation: isolate;
    background-color: var(--color-background-warm);
    color: var(--color-primary);
    /* Bottom padding lifts the legal row above the decoration's dark-green
       ellipse so its text stays on the light cream area and readable. The
       ellipse fills roughly the bottom ~100px of the artwork at natural size,
       and on mobile/tablet the stacked legal sits right over the centred
       ellipse — so it needs ~112px there. Wide desktop drops to 60px (below),
       where the legal sits out at the left/right edges, clear of the ellipse. */
    padding: 5rem 0 7rem;
    font-family: 'Raleway', sans-serif;
    overflow: hidden;
  }

  /* Decorative background (Figma 110:6385): overlapping translucent
     ellipses (decoration.svg), anchored to the bottom.
       • ≥ 1440px: scales up to fill the full width, so the composition
         always reaches both edges — no clipped gap on large screens.
       • < 1440px: holds its natural 1440px width and is simply cropped at
         the sides (centered) — it never scales down.
     `max(100%, 1440px)` expresses both in one value. The SVG bakes in its
     own ellipse opacity (0.75 / 0.85), so it renders at full strength. */
  .footer::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('/decoration.svg');
    background-size: max(100%, 1440px) auto;
    background-position: center bottom;
    background-repeat: no-repeat;
    pointer-events: none;
    z-index: 0;
  }

  .footer__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* Top section: brand on left, columns on right.
     Stacks on mobile/tablet (brand on top), side-by-side on desktop
     ≥1024px. Threshold is 1024 (not 768) because brand 24rem +
     columns ~27rem + 4rem gap = ~55rem (880px) of content + container
     padding needs ~960-1000px to breathe — below that the row gets
     cramped, so columns wrap below the brand instead. */
  .footer__main {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  @media (min-width: 1024px) {
    /* Centering inside the taller section handles the top space, so the
       footer needs no extra top padding on desktop. */
    .footer {
      padding-top: 0;
    }
    .footer__main {
      /* Grid (not flex) so the content row sits vertically centered within
         the taller section while brand + columns stay top-aligned with
         each other. */
      display: grid;
      grid-template-columns: 24rem 1fr;
      align-items: start;
      align-content: center;
      gap: 4rem;
      /* Taller content section per Figma 110:6385. */
      min-height: 650px;
    }
  }

  /* Wide desktop: the legal row sits out at the left/right edges, clear of
     the centred dark-green ellipse, so it no longer needs the extra lift —
     back to the 60px bottom padding. */
  @media (min-width: 1200px) {
    .footer {
      padding-bottom: 3.75rem;
    }
  }

  /* Brand column: logo + bedrijfsinfo stacked vertically. Fixed width
     on the desktop breakpoint (where brand sits next to columns);
     left to flow naturally below desktop so it can take the full
     container width when stacked. */
  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 24rem;
  }

  /* More breathing room between the (now larger) wordmark and the
     bedrijfsinfo beneath it on desktop. */
  @media (min-width: 768px) {
    .footer__brand {
      gap: 2.5rem;
    }
  }

  @media (min-width: 1024px) {
    .footer__brand {
      flex: 0 0 auto;
      width: 24rem;
    }
  }

  .footer__logo-link {
    display: block;
    width: fit-content;
    text-decoration: none;
    color: var(--color-primary);
    transition: opacity 0.2s ease;
  }

  .footer__logo-link:hover {
    opacity: 0.9;
  }

  .footer__logo-link:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 4px;
  }

  /* Logo size per Figma redesign — smaller than before. Bigger on mobile
     for legibility, smaller on desktop where the columns get the spotlight. */
  .footer__logo-img {
    display: block;
    width: 16rem; /* 256px — mobile */
    height: auto;
    max-width: 100%;
  }

  @media (min-width: 768px) {
    .footer__logo-img {
      /* Larger desktop wordmark. Stays within the 24rem brand column so the
         Menu/Contact columns (flex:1 of the remainder) never lose room and
         wrap — the brand box is a fixed 24rem, so logo size doesn't touch them. */
      width: 22rem; /* 352px — desktop */
    }
  }

  /* Bedrijfsinfo block — no heading, just the list with icons */
  .footer__bedrijfsinfo {
    margin: 0;
  }

  /* Right-side columns: Menu + Contact. Row by default with
     `flex-wrap: wrap` so they stay side-by-side as long as both fit;
     they only stack underneath each other when the viewport is too
     narrow (small mobile, < ~432px container — matches Menu's 11rem
     min-width + Contact's 12rem + 4rem gap). On desktop the columns
     are pushed to the right edge to sit opposite the brand block. */
  .footer__columns {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 2.5rem 4rem; /* row-gap col-gap */
  }

  @media (min-width: 1024px) {
    .footer__columns {
      flex: 1;
      justify-content: flex-end;
      align-items: flex-start;
    }
  }

  .footer__block {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* min-widths set the wrap-threshold for the columns. With these in
     place, Menu+Contact wrap below each other only when the columns
     container falls below ~27rem (≈432px) — narrow phones. */
  .footer__block--menu {
    min-width: 11rem;
  }
  .footer__block--contact {
    min-width: 12rem;
  }

  .footer__heading {
    /* Spectral Medium — slightly smaller on mobile so it doesn't crowd. */
    font-family: 'Spectral', serif;
    font-size: 1.375rem; /* 22px mobile */
    font-weight: 500;
    letter-spacing: -1px;
    color: var(--color-primary);
    margin: 0;
    line-height: 1.2;
  }

  @media (min-width: 768px) {
    .footer__heading {
      font-size: 1.75rem; /* 28px desktop */
      letter-spacing: -1.5px;
    }
  }

  .footer__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer__link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-primary);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 400;
    padding: 0.5rem 0.75rem;
    margin: -0.5rem -0.75rem;
    border-radius: 9999px;
    transition: color 0.2s ease;
    z-index: 1;
  }

  .footer__link:hover,
  .footer__link:focus-visible {
    color: var(--color-primary);
    opacity: 0.85;
  }

  .footer__link--active {
    color: var(--color-primary);
    font-weight: 600;
  }

  .footer__link--text {
    cursor: default;
    margin: 0;
    padding: 0;
  }

  /* Inert text rows: keep them readable on hover instead of flipping to
     white (which used to make them disappear against the cream). */
  .footer__link--text:hover,
  .footer__link--text:focus-visible {
    background: none;
    color: var(--color-primary);
    opacity: 1;
  }

  .footer__link-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
  }

  .footer__link-icon :global(svg) {
    width: 1.25rem;
    height: 1.25rem;
  }

  .footer__link-text {
    display: inline-block;
    flex: 1;
    min-width: 0;
  }

  .footer__dot {
    display: inline-block;
    width: 4px;
    height: 4px;
    margin: 0 0.35rem;
    vertical-align: middle;
    background-color: var(--color-accent);
    border-radius: 50%;
  }

  .footer__socials {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  /* Legal row at the bottom (Figma 110:6441). The extra bottom padding on
     .footer lifts this row above the decoration's dark-green ellipse, so the
     muted-green text sits on the light cream area and stays readable on every
     screen size (no background pill needed). */
  .footer__legal {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.875rem; /* 14px on mobile so the copy pill fits narrow phones */
    letter-spacing: -0.01em;
    color: #2b503c;
  }

  @media (min-width: 768px) {
    .footer__legal {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      font-size: 1rem; /* 16px per Figma on desktop */
    }
  }

  .footer__legal-links,
  .footer__legal-copy {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  @media (min-width: 768px) {
    .footer__legal-links,
    .footer__legal-copy {
      gap: 0.75rem;
    }
  }

  /* The gap sets the spacing between the legal items, so the dot doesn't
     need its own horizontal margin here. */
  .footer__legal .footer__dot {
    margin: 0;
  }

  /* Legal anchors inherit the muted-green from the parent. */
  .footer__legal-link {
    color: inherit;
    text-decoration: none;
  }

  .footer__legal-link:hover {
    text-decoration: underline;
  }
</style>
