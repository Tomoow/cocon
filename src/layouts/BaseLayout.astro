---
/**
 * Base layout: imports global Tailwind styles, sets up SEO metadata
 * (title/description/canonical/Open Graph/Twitter), and renders the
 * semantic document shell.
 *
 * Per-page knobs:
 *   - title       short page label; "| Cocon Kinesitherapie" is appended
 *                 automatically except on the home page (isHome)
 *   - description meta description (~150-160 chars ideal)
 *   - ogImage     absolute or root-relative URL of the social-share image
 *   - isHome      home gets its own non-suffixed title and includes the
 *                 LocalBusiness JSON-LD
 */
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  isHome?: boolean;
  /** When true, `title` is used verbatim (no "| Cocon Kinesitherapie"
   *  suffix). For subpages that carry their own brand + location in the
   *  title, e.g. tarieven. */
  plainTitle?: boolean;
  /** When true, emits `<meta name="robots" content="noindex,nofollow">`
   *  so search engines exclude the page from their index. Use for legal
   *  pages, post-submit confirmation pages, etc. — anything that would
   *  look out of place as a standalone Google result. */
  noindex?: boolean;
}

const {
  title,
  description = 'Cocon is een kinesitherapiepraktijk in Kapelle-op-den-Bos, gespecialiseerd in bekkenbodemtherapie, zwangerschapsbegeleiding, revalidatie en algemene klachten.',
  // Versioned filename: bump the suffix when the card changes — Cloudflare's
  // edge (24h /images/* cache) and social scrapers (WhatsApp/Facebook cache
  // by URL) both pick a new URL up immediately, a changed file at the same
  // URL only after their caches expire.
  ogImage = '/images/og-card-v2.png',
  isHome = false,
  plainTitle = false,
  noindex = false,
} = Astro.props;

// Social-share image metadata. The default og-card.png is a dedicated
// 1200×630 landscape card (WhatsApp/Facebook/LinkedIn crop portrait
// images badly); width/height let scrapers reserve the right box before
// downloading, alt is read by assistive tech on platforms that support it.
const ogImageWidth = 1200;
const ogImageHeight = 630;
const ogImageAlt = 'Cocon — kinesitherapie & bekkenbodemtherapie in Kapelle-op-den-Bos';

// Canonical URL — astro `site` is the production base. Astro.url.pathname
// gives the current path so each page has its own canonical.
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://kine-cocon.be').href;
const absoluteOgImage = new URL(ogImage, Astro.site ?? 'https://kine-cocon.be').href;

// Compose the title. Home leads with the service + location keywords
// (Google truncates around 55-60 chars, so the location must survive);
// subpages append the brand so it's clear which site the page belongs
// to in Google's results, unless the page brings its own full title.
const pageTitle = isHome
  ? 'Kinesitherapie & bekkenbodemtherapie Kapelle-op-den-Bos | Cocon'
  : plainTitle
    ? title
    : `${title} | Cocon Kinesitherapie`;

// LocalBusiness JSON-LD — only emitted on the home page so we don't
// duplicate the practice's identity across every page. Helps Google
// surface the practice in the Map / local pack once Business Profile
// verification is also done.
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'Physiotherapy',
  // Stable entity id so other pages' markup (e.g. the Person schema on
  // /over-ons/) can reference this exact business node.
  '@id': 'https://kine-cocon.be/#business',
  name: 'Cocon Kinesitherapie',
  description,
  url: 'https://kine-cocon.be',
  telephone: '+32456864665',
  email: 'info@kine-cocon.be',
  image: absoluteOgImage,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Mechelseweg 62',
    addressLocality: 'Kapelle-op-den-Bos',
    postalCode: '1880',
    addressCountry: 'BE',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 51.0124,
    longitude: 4.3803,
  },
  hasMap: 'https://www.google.com/maps/search/?api=1&query=Mechelseweg+62+1880+Kapelle-op-den-Bos',
  areaServed: {
    '@type': 'Place',
    name: 'Kapelle-op-den-Bos en omgeving',
  },
  priceRange: '€37 - €60',
  paymentAccepted: 'Payconiq',
  currenciesAccepted: 'EUR',
  vatID: 'BE 1004.016.118',
  foundingDate: '2026-08-10',
  founder: {
    '@type': 'Person',
    '@id': 'https://kine-cocon.be/over-ons/#lynn',
    name: 'Lynn Beunnens',
  },
  // Practice opens August 2026; openingHoursSpecification can be added
  // when the schedule is finalised (hours currently live on the Google
  // Business Profile).
  sameAs: ['https://www.instagram.com/kine_cocon/'],
};
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <!-- Favicon: SVG as default (best practice), PNG fallbacks for older
         contexts. Cache-bust query so returning visitors who already cached
         the previous favicon actually see the updated one — browsers ignore
         normal cache headers for favicons and only re-fetch when the URL
         changes. Bump `?v=N` whenever the file changes. -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=2" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=2" />
    <link rel="apple-touch-icon" sizes="32x32" href="/favicon-32x32.png?v=2" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonicalURL} />
    <title>{pageTitle}</title>

    <!-- Open Graph (Facebook, WhatsApp, LinkedIn, etc. link previews) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content="nl_BE" />
    <meta property="og:site_name" content="Cocon Kinesitherapie" />

    <!-- Twitter card (mostly used by Twitter/X but other apps read it too) -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    {isHome && (
      <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    )}

    <!-- Umami Analytics: cookieless, GDPR-friendly page view + event tracking.
         Custom events are wired across the site via `data-umami-event="..."`
         on CTAs and programmatically on successful contact-form submit. See
         docs/TRACKING.md for the full inventory. -->
    <script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="db0345e1-ced4-4bf3-8607-6474b5cce507"></script>

    <!-- Fonts are self-hosted via @fontsource (imported in global.css) —
         no third-party font origins. -->

    <!-- JS detection: the .fade-in hidden state in global.css is scoped to
         `.js` so content stays visible when JavaScript is disabled/blocked.
         Inline + first so it runs before first paint. -->
    <script is:inline>document.documentElement.classList.add('js');</script>
  </head>
  <body class="min-h-screen antialiased bg-background-subtle">
    <!-- Shared clipPath for info card image: angle other way, wider, bloater (fuller oval) -->
    <svg aria-hidden="true" style="position: absolute; width: 0; height: 0;">
      <defs>
        <clipPath id="info-card-ellipse" clipPathUnits="objectBoundingBox">
          <ellipse cx="0.32" cy="0.8" rx="0.6" ry="0.8" transform="rotate(-22 0.5 0.7) matrix(0.507372 0.861727 0.87022 -0.492664 -0.15 0.35)" />
        </clipPath>
      </defs>
    </svg>
    <!-- Skip link: first focusable element on every page (WCAG 2.4.1) -->
    <a href="#main-content" class="skip-link">Ga naar inhoud</a>
    <Header currentPath={Astro.url.pathname} />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer currentPath={Astro.url.pathname} />
    <BackToTop />
  </body>
</html>

<script>
  // Defer non-critical: Fade-in animation not needed for initial render
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFadeIn);
  } else {
    setTimeout(initFadeIn, 0);
  }
  
  function initFadeIn() {
    const elements = document.querySelectorAll('.fade-in');

    if (elements.length === 0) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            // Unobserve after animation to prevent re-triggering
            observer.unobserve(entry.target);
          }
        });
      },
      {
        threshold: 0.1, // Trigger when 10% of element is visible
        rootMargin: '0px 0px -50px 0px', // Start animation slightly before element enters viewport
      }
    );

    elements.forEach((el) => observer.observe(el));
  }
</script>
