/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Astro content-hashes everything under /_astro/ (JS, fonts, optimized
# images), so a new build always gets new URLs — safe to cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Static assets referenced by fixed URLs (not hashed): cache for a day so
# repeat visits skip the revalidation round trip, while updates still land
# within 24h.
/images/*
  Cache-Control: public, max-age=86400

/logo/*
  Cache-Control: public, max-age=86400
